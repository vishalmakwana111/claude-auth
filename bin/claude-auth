#!/usr/bin/env python3
"""
claude-auth — switch between multiple Claude Code accounts on one machine.

Like `gh auth switch`, but for Claude Code. Snapshots the currently logged-in
account (Keychain credential blob + ~/.claude.json identity) into a named
profile, and restores any saved profile on demand.

macOS only (uses the login Keychain via the `security` CLI). Secret tokens stay
in the Keychain; only non-secret identity metadata is kept in a plaintext index.
"""

import sys
import os
import re
import json
import time
import shutil
import getpass
import signal
import threading
import subprocess
import argparse
import urllib.request
import urllib.error
import http.client
import concurrent.futures
from http.server import ThreadingHTTPServer, BaseHTTPRequestHandler
from datetime import datetime, timezone

__version__ = "1.8.0"

API_USAGE = "https://api.anthropic.com/api/oauth/usage"
OAUTH_BETA = "oauth-2025-04-20"
ANTHROPIC_VERSION = "2023-06-01"
OAUTH_TOKEN_URL = "https://platform.claude.com/v1/oauth/token"
OAUTH_CLIENT_ID = "9d1c250a-e61b-44d9-88ed-5944d1962f5e"

HOME = os.path.expanduser("~")
CLAUDE_JSON = os.path.join(HOME, ".claude.json")
SETTINGS = os.path.join(HOME, ".claude", "settings.json")
STORE_DIR = os.path.join(HOME, ".claude-accounts")
INDEX_PATH = os.path.join(STORE_DIR, "accounts.json")

AUTOSWITCH_DEFAULTS = {
    "enabled": False,
    "threshold": 90,        # switch when usage exceeds this %
    "window": "session",    # which limit to watch: session | week
    "strategy": "next",     # next = round-robin, lowest = most headroom
    "intervalSec": 120,     # minimum seconds between checks
    "lastCheckAt": 0,
}

LIVE_SERVICE = "Claude Code-credentials"   # the item Claude Code itself reads
STORE_SERVICE = "claude-auth-store"         # our namespaced backups, per account

# pool proxy (see the "pool" section near the bottom)
DEFAULT_POOL_PORT = 8848
POOL_PID   = os.path.join(STORE_DIR, "pool.pid")
POOL_STATE = os.path.join(STORE_DIR, "pool.json")
POOL_LOG   = os.path.join(STORE_DIR, "pool.log")
# headers that must NOT be copied through a proxy (RFC 7230 §6.1)
_HOP_BY_HOP = {
    "connection", "keep-alive", "proxy-authenticate", "proxy-authorization",
    "te", "trailer", "trailers", "transfer-encoding", "upgrade",
}
POOL = None  # the live _Pool instance, set inside the `pool serve` daemon

REPO = "github.com/vishalmakwana111/claude-auth"
# Raw URL of the canonical script on the default branch — used by `update`.
RAW_SCRIPT_URL = "https://raw.githubusercontent.com/vishalmakwana111/claude-auth/main/bin/claude-auth"

# ───────────────────────────── theme ──────────────────────────────────────

_NO_COLOR = bool(os.environ.get("NO_COLOR"))
_TTY = sys.stdout.isatty() and not _NO_COLOR

# Claude's warm "clay" palette (truecolor 24-bit)
CLAY      = (204, 120, 92)     # primary brand
CLAY_LITE = (236, 170, 120)
CLAY_DARK = (150, 78, 58)
INK       = (236, 223, 196)    # warm off-white
MUTE      = (140, 140, 140)
OK        = (122, 192, 140)
WARN      = (228, 182, 86)
ERR       = (226, 110, 102)
ACCENT    = (140, 174, 244)    # soft blue for numbers / links

def _fg(rgb, s):
    if not _TTY:
        return s
    r, g, b = rgb
    return f"\033[38;2;{r};{g};{b}m{s}\033[0m"

def _sgr(code, s):
    return f"\033[{code}m{s}\033[0m" if _TTY else s

def bold(s):   return _sgr("1", s)
def dim(s):    return _fg(MUTE, s)
def clay(s):   return _fg(CLAY, s)
def green(s):  return _fg(OK, s)
def red(s):    return _fg(ERR, s)
def yellow(s): return _fg(WARN, s)
def cyan(s):   return _fg(ACCENT, s)
def ink(s):    return _fg(INK, s)

_ANSI_RE = re.compile(r"\033\[[0-9;]*m")
def vlen(s):
    """Visible width, ignoring ANSI escapes."""
    return len(_ANSI_RE.sub("", s))

def vpad(s, width, align="left"):
    pad = max(0, width - vlen(s))
    return (" " * pad + s) if align == "right" else (s + " " * pad)

def _lerp(a, b, t):
    return tuple(round(a[i] + (b[i] - a[i]) * t) for i in range(3))

def gradient(text, c1, c2):
    """Horizontal color sweep c1 → c2 across the characters of `text`."""
    if not _TTY:
        return text
    n = max(1, len(text) - 1)
    return "".join(_fg(_lerp(c1, c2, i / n), ch) for i, ch in enumerate(text))

def term_width():
    try:
        return shutil.get_terminal_size((80, 24)).columns
    except Exception:
        return 80

def rel_time(ts):
    """Human 'time ago' from a unix-seconds timestamp."""
    if not ts:
        return "—"
    d = int(time.time()) - int(ts)
    if d < 0:
        d = 0
    if d < 60:
        return "just now"
    for unit, secs in (("d", 86400), ("h", 3600), ("m", 60)):
        if d >= secs:
            return f"{d // secs}{unit} ago"
    return "just now"

# ─────────────────────────── usage / limits ───────────────────────────────

def fetch_usage(access_token, timeout=8):
    """GET /api/oauth/usage. Returns (data, None) or (None, error)."""
    req = urllib.request.Request(API_USAGE, headers={
        "Authorization": f"Bearer {access_token}",
        "anthropic-beta": OAUTH_BETA,
        "anthropic-version": ANTHROPIC_VERSION,
        "User-Agent": f"claude-auth/{__version__}",
    })
    try:
        with urllib.request.urlopen(req, timeout=timeout) as r:
            return json.loads(r.read().decode()), None
    except urllib.error.HTTPError as e:
        return None, ("expired" if e.code == 401 else f"http {e.code}")
    except Exception as e:
        return None, str(e).split("]")[-1].strip()[:40] or "network error"

def parse_usage(d):
    """Normalize the API response to the windows we display."""
    def win(key):
        w = d.get(key) or {}
        u = w.get("utilization")
        if u is None:
            return None
        return {"pct": float(u), "resets_at": w.get("resets_at")}
    return {
        "session": win("five_hour"),
        "week": win("seven_day"),
        "week_sonnet": win("seven_day_sonnet"),
        "week_opus": win("seven_day_opus"),
    }

def refresh_access_token(refresh_token, timeout=10):
    """Exchange a refresh token for a fresh credential. Returns (data, err)."""
    body = json.dumps({
        "grant_type": "refresh_token",
        "refresh_token": refresh_token,
        "client_id": OAUTH_CLIENT_ID,
    }).encode()
    req = urllib.request.Request(OAUTH_TOKEN_URL, data=body, method="POST", headers={
        "Content-Type": "application/json",
        "User-Agent": f"claude-auth/{__version__}",
    })
    try:
        with urllib.request.urlopen(req, timeout=timeout) as r:
            return json.loads(r.read().decode()), None
    except urllib.error.HTTPError as e:
        return None, f"http {e.code}"
    except Exception as e:
        return None, str(e).split("]")[-1].strip()[:40] or "network error"

def refresh_stored(name, idx=None):
    """Refresh an inactive account's Keychain backup in place. (ok, err)."""
    raw = kc_read(STORE_SERVICE, name)
    if raw is None:
        return False, "no stored credential"
    blob = json.loads(raw)
    cred = blob.get("claudeAiOauth", {})
    rt = cred.get("refreshToken")
    if not rt:
        return False, "no refresh token"
    data, err = refresh_access_token(rt)
    if data is None:
        return False, err
    at = data.get("access_token")
    if not at:
        return False, "no access_token in response"
    cred["accessToken"] = at
    if data.get("refresh_token"):
        cred["refreshToken"] = data["refresh_token"]
    if data.get("expires_in"):
        cred["expiresAt"] = int((time.time() + data["expires_in"]) * 1000)
    blob["claudeAiOauth"] = cred
    kc_write(STORE_SERVICE, name, json.dumps(blob), label=f"claude-auth: {name}")
    if idx is not None and name in idx["accounts"]:
        idx["accounts"][name]["expiresAt"] = cred.get("expiresAt")
    return True, None

def sev_color(pct):
    if pct is None:
        return dim
    return green if pct < 50 else (yellow if pct < 80 else red)

def bar(pct, width=12):
    """Colored utilization bar; visible width is always `width`."""
    if pct is None:
        return dim("░" * width)
    p = max(0.0, min(100.0, pct))
    filled = round(width * p / 100)
    return sev_color(p)("█" * filled) + dim("░" * (width - filled))

def pct_str(pct):
    return "  —" if pct is None else f"{round(pct):>3d}%"

def _parse_iso(s):
    if not s:
        return None
    try:
        return datetime.fromisoformat(s)
    except ValueError:
        return None

def resets_at_str(iso):
    """Local clock time the window resets, e.g. '9:59pm' or 'Jun 25 3:29am'."""
    dt = _parse_iso(iso)
    if not dt:
        return ""
    if dt.tzinfo is None:
        dt = dt.replace(tzinfo=timezone.utc)
    local = dt.astimezone()
    now = datetime.now().astimezone()
    clock = f"{local.strftime('%-I:%M')}{local.strftime('%p').lower()}"
    if local.date() == now.date():
        return clock
    return f"{local.strftime('%b %-d')} {clock}"

# ─────────────────────────── messages ─────────────────────────────────────

IND = "  "

def info(msg=""):
    print(msg)

def ok(msg):
    info(IND + green("✓") + " " + msg)

def warn(msg):
    info(IND + yellow("!") + " " + msg)

def step(msg):
    info(IND + clay("›") + " " + msg)

def hint(msg):
    info(IND + dim(msg))

def die(msg, code=1):
    print(IND + red("✗") + " " + msg, file=sys.stderr)
    sys.exit(code)

# ──────────────────────────── banner / help ───────────────────────────────

_WORDMARK = [
    " ██████╗██╗      █████╗ ██╗   ██╗██████╗ ███████╗",
    "██╔════╝██║     ██╔══██╗██║   ██║██╔══██╗██╔════╝",
    "██║     ██║     ███████║██║   ██║██║  ██║█████╗  ",
    "██║     ██║     ██╔══██║██║   ██║██║  ██║██╔══╝  ",
    "╚██████╗███████╗██║  ██║╚██████╔╝██████╔╝███████╗",
    " ╚═════╝╚══════╝╚═╝  ╚═╝ ╚═════╝ ╚═════╝ ╚══════╝",
]

def render_banner():
    out = []
    if term_width() >= 54:
        width = max(len(l) for l in _WORDMARK)
        for line in _WORDMARK:
            out.append(IND + gradient(line.ljust(width), CLAY_LITE, CLAY_DARK))
        out.append(IND + bold(clay("auth")) +
                   dim("  ·  multi-account switcher for Claude Code"))
    else:
        out.append(IND + clay("◆ ") + bold(ink("claude-auth")))
        out.append(IND + dim("multi-account switcher for Claude Code"))
    return "\n".join(out)

def _play_cat():
    """A cat walks continuously across the full width of the CLI, then stops.
    No-op unless we're attached to a real terminal."""
    if not sys.stdout.isatty() or os.environ.get("CLAUDE_AUTH_NO_ANIM"):
        return
    w = term_width()
    cw = 8                       # cat width incl. wagging tail
    if w < cw + 12:
        return                   # too narrow to be cute
    h = 3
    out = sys.stdout
    target = w - cw - 1          # walk all the way to the right edge
    step = max(1, target // 80)  # ~1 col/frame; coarser on very wide terminals
    frames = max(1, target // step)
    delay = min(0.04, max(0.012, 1.2 / frames))
    g = lambda s: gradient(s, CLAY_LITE, CLAY)
    try:
        out.write("\033[?25l")              # hide cursor
        out.write("\n" * h)                 # reserve drawing area
        for i in range(frames + 1):
            x = min(target, i * step)
            eyes = "-.-" if i % 9 == 5 else "o.o"      # occasional blink
            tail = "~ " if i % 2 else " ~"             # wag
            cat = [" /\\_/\\ ", f"( {eyes} )", f" > ^ <{tail}"]
            out.write(f"\033[{h}A")                     # up to top of area
            for ln in cat:
                out.write("\033[2K" + " " * x + g(ln) + "\n")
            out.flush()
            time.sleep(delay)
        # stop at the right edge — happy face, with the meow trailing behind it
        meow = clay("meow~ ♪ ")                          # 8 visible cols
        pad = " " * max(0, target - 8)
        arrival = [
            " " * target + g(" /\\_/\\ "),
            pad + meow + g("( ^.^ )"),
            " " * target + g(" > ^ <  "),
        ]
        out.write(f"\033[{h}A")
        for ln in arrival:
            out.write("\033[2K" + ln + "\n")
        out.flush()
        time.sleep(0.4)
    except Exception:
        pass
    finally:
        try:
            out.write("\033[?25h")          # always restore cursor
            out.flush()
        except Exception:
            pass

def render_help():
    rows = [
        ("login",   "[name]",       "Sign in fresh, then save as a profile"),
        ("add",     "[name]",       "Save the currently logged-in account"),
        ("switch",  "[name]",       "Switch to a saved account"),
        ("usage",   "[name]",       "Show rate-limit usage across accounts"),
        ("autoswitch", "[on|off]",  "Auto-switch accounts when usage gets high"),
        ("pool",    "[start|stop]",  "Pool all accounts behind one auto-failover proxy"),
        ("refresh", "[name]",       "Refresh stored tokens of inactive accounts"),
        ("statusline", "",          "Compact status line for Claude Code"),
        ("list",    "",             "List saved accounts" + dim("  (alias: ls)")),
        ("current", "",             "Show the active account" + dim("  (alias: whoami)")),
        ("rename",  "<old> <new>",  "Rename a saved profile"),
        ("remove",  "<name>",       "Delete a saved profile" + dim("  (alias: rm)")),
        ("doctor",  "",             "Health-check your setup"),
        ("update",  "",             "Update claude-auth to the latest version"),
        ("completion", "[bash|zsh]", "Output shell completion"),
        ("commands", "",            "Show all commands (cheat sheet)"),
    ]
    cw = max(len(c) for c, _, _ in rows)
    aw = max(len(a) for _, a, _ in rows)
    L = ["", render_banner(), ""]
    L.append(IND + bold(clay("USAGE")))
    L.append(IND * 2 + ink("claude-auth") + " " + dim("<command> [options]"))
    L.append("")
    L.append(IND + bold(clay("COMMANDS")))
    for c, a, d in rows:
        L.append(IND * 2 + bold(ink(vpad(c, cw))) + "  " +
                 dim(vpad(a, aw)) + "  " + d)
    L.append("")
    L.append(IND + bold(clay("EXAMPLES")))
    for ex in ("claude-auth login work", "claude-auth switch personal", "claude-auth list"):
        L.append(IND * 2 + dim("$ ") + clay(ex))
    L.append("")
    L.append(IND + dim("docs   ") + cyan(REPO) + dim(f"   ·   v{__version__}"))
    L.append("")
    return "\n".join(L)

# ───────────────────────────── keychain ───────────────────────────────────

def _kc_account_for_live():
    """The macOS account name the live credential item is stored under."""
    try:
        out = subprocess.run(
            ["security", "find-generic-password", "-s", LIVE_SERVICE],
            capture_output=True, text=True,
        ).stdout
        for line in out.splitlines():
            line = line.strip()
            if line.startswith('"acct"<blob>='):
                val = line.split("=", 1)[1].strip()
                if val.startswith('"') and val.endswith('"'):
                    return val[1:-1]
    except Exception:
        pass
    return getpass.getuser()

def kc_read(service, account):
    """Return the password string for a keychain item, or None if absent."""
    r = subprocess.run(
        ["security", "find-generic-password", "-s", service, "-a", account, "-w"],
        capture_output=True, text=True,
    )
    if r.returncode != 0:
        return None
    return r.stdout.rstrip("\n")

def kc_write(service, account, secret, label=None):
    """Create or update a keychain item in place (-U preserves ACL)."""
    cmd = ["security", "add-generic-password", "-U",
           "-s", service, "-a", account, "-w", secret]
    if label:
        cmd += ["-l", label]
    r = subprocess.run(cmd, capture_output=True, text=True)
    if r.returncode != 0:
        die(f"keychain write failed: {r.stderr.strip()}")

def kc_delete(service, account):
    subprocess.run(
        ["security", "delete-generic-password", "-s", service, "-a", account],
        capture_output=True, text=True,
    )

# ─────────────────────── live credential + identity ───────────────────────

def read_live_credential():
    acct = _kc_account_for_live()
    raw = kc_read(LIVE_SERVICE, acct)
    if raw is None:
        return None, acct
    try:
        return json.loads(raw), acct
    except json.JSONDecodeError:
        die("live Keychain credential is not valid JSON")

def write_live_credential(blob, acct):
    kc_write(LIVE_SERVICE, acct, json.dumps(blob), label=LIVE_SERVICE)

def read_claude_json():
    try:
        with open(CLAUDE_JSON) as f:
            return json.load(f)
    except FileNotFoundError:
        return {}
    except json.JSONDecodeError:
        die(f"{CLAUDE_JSON} is not valid JSON")

def write_claude_json(data):
    # atomic write to avoid corrupting the (large) config on crash
    tmp = CLAUDE_JSON + ".claude-auth.tmp"
    with open(tmp, "w") as f:
        json.dump(data, f, indent=2)
    os.replace(tmp, CLAUDE_JSON)

def current_identity():
    """(oauthAccount dict, userID) for the currently logged-in account."""
    cj = read_claude_json()
    return cj.get("oauthAccount") or {}, cj.get("userID")

# ───────────────────────────── index ──────────────────────────────────────

def load_index():
    try:
        with open(INDEX_PATH) as f:
            return json.load(f)
    except FileNotFoundError:
        return {"accounts": {}}
    except json.JSONDecodeError:
        die(f"{INDEX_PATH} is corrupt")

def save_index(idx):
    os.makedirs(STORE_DIR, exist_ok=True)
    try:
        os.chmod(STORE_DIR, 0o700)
    except OSError:
        pass
    tmp = INDEX_PATH + ".tmp"
    with open(tmp, "w") as f:
        json.dump(idx, f, indent=2)
    os.replace(tmp, INDEX_PATH)
    try:
        os.chmod(INDEX_PATH, 0o600)
    except OSError:
        pass

def active_name(idx):
    """Name of the saved profile matching the live identity, or None."""
    oauth, _ = current_identity()
    uuid = oauth.get("accountUuid")
    if not uuid:
        return None
    for name, p in idx["accounts"].items():
        if p.get("accountUuid") == uuid:
            return name
    return None

# ─────────────────────────── snapshot / restore ───────────────────────────

def snapshot_into(name, idx, *, quiet=False):
    """Capture the live account into profile `name`."""
    blob, _ = read_live_credential()
    if blob is None:
        die("no live Claude Code credential found in Keychain — log in first")
    oauth, user_id = current_identity()

    kc_write(STORE_SERVICE, name, json.dumps(blob), label=f"claude-auth: {name}")
    cred = blob.get("claudeAiOauth", {})
    idx["accounts"][name] = {
        "email": oauth.get("emailAddress"),
        "organizationName": oauth.get("organizationName"),
        "accountUuid": oauth.get("accountUuid"),
        "userID": user_id,
        "subscriptionType": cred.get("subscriptionType"),
        "expiresAt": cred.get("expiresAt"),
        "oauthAccount": oauth,
        "addedAt": idx["accounts"].get(name, {}).get("addedAt", int(time.time())),
        "updatedAt": int(time.time()),
    }
    save_index(idx)
    if not quiet:
        email = oauth.get("emailAddress") or "?"
        ok(f"Saved {bold(clay(name))}  {dim('· ' + email)}")

def restore(name, idx):
    """Make profile `name` the active account."""
    if name not in idx["accounts"]:
        die(f"no such account: {name}")
    raw = kc_read(STORE_SERVICE, name)
    if raw is None:
        die(f"stored credential for {name} is missing from Keychain (was it deleted?)")
    blob = json.loads(raw)

    _, acct = read_live_credential()
    write_live_credential(blob, acct)

    # restore identity into ~/.claude.json so the displayed account is correct
    prof = idx["accounts"][name]
    cj = read_claude_json()
    if prof.get("oauthAccount"):
        cj["oauthAccount"] = prof["oauthAccount"]
    if prof.get("userID") is not None:
        cj["userID"] = prof["userID"]
    write_claude_json(cj)

# ───────────────────────────── commands ───────────────────────────────────

def cmd_login(args):
    """Drive `claude auth login`, then save whatever account we land on."""
    idx = load_index()

    # don't lose the outgoing account — login overwrites the live credential
    active = active_name(idx)
    if active:
        snapshot_into(active, idx, quiet=True)
    prev_oauth, _ = current_identity()
    prev_uuid = prev_oauth.get("accountUuid")

    cmd = ["claude", "auth", "login"]
    if args.console:
        cmd.append("--console")
    if args.sso:
        cmd.append("--sso")
    if args.email:
        cmd += ["--email", args.email]

    info()
    step("Launching " + clay("claude auth login") + " — finish sign-in in your browser…")
    info()
    try:
        r = subprocess.run(cmd)
    except FileNotFoundError:
        die("`claude` CLI not found on PATH")
    if r.returncode != 0:
        die("login was cancelled or failed; nothing saved")

    new_oauth, _ = current_identity()
    new_uuid = new_oauth.get("accountUuid")
    if not new_uuid:
        die("login finished but no account could be read — try `claude-auth add`")

    email = new_oauth.get("emailAddress") or ""
    name = args.name or (email.split("@")[0] if email else None)
    if not name:
        die("could not infer a name; pass one: claude-auth login <name>")

    for n, p in idx["accounts"].items():
        if p.get("accountUuid") == new_uuid and n != name:
            warn(f"this account is already saved as {bold(n)}")

    info()
    snapshot_into(name, idx)
    if prev_uuid and prev_uuid == new_uuid:
        hint("(same account as before — refreshed its stored tokens)")
    info()

def cmd_add(args):
    idx = load_index()
    oauth, _ = current_identity()
    email = oauth.get("emailAddress") or ""
    name = args.name or (email.split("@")[0] if email else None)
    if not name:
        die("could not infer a name; pass one: claude-auth add <name>")
    if name in idx["accounts"] and not args.force:
        die(f"'{name}' already exists — pass {bold('--force')} to overwrite")
    info()
    snapshot_into(name, idx)
    info()

def _cell(text, w, colorfn, align="left"):
    return " " + colorfn(vpad(text, w, align)) + " "

def cmd_list(args):
    idx = load_index()
    accts = idx["accounts"]
    info()
    if not accts:
        hint("No saved accounts yet.")
        info(IND + dim("Get started:  ") + clay("claude-auth login <name>") +
             dim("  or  ") + clay("claude-auth add"))
        info()
        return

    active = active_name(idx)
    rows = []
    for name, p in sorted(accts.items()):
        rows.append({
            "active": name == active,
            "name": name,
            "email": p.get("email") or "—",
            "org": p.get("organizationName") or "—",
            "plan": p.get("subscriptionType") or "—",
            "saved": rel_time(p.get("updatedAt")),
        })

    w_name = max(len("ACCOUNT"), max(len(r["name"]) for r in rows))
    w_mail = max(len("EMAIL"),   max(len(r["email"]) for r in rows))
    w_org  = max(len("ORG"),     max(len(r["org"]) for r in rows))
    w_plan = max(len("PLAN"),    max(len(r["plan"]) for r in rows))
    w_save = max(len("SAVED"),   max(len(r["saved"]) for r in rows))
    widths = [1, w_name, w_mail, w_org, w_plan, w_save]

    def border(l, m, rt):
        return dim(l + m.join("─" * (w + 2) for w in widths) + rt)

    def line(cells):
        return IND + dim("│") + dim("│").join(cells) + dim("│")

    H = lambda s: bold(dim(s))
    n = len(rows)
    info(IND + bold(clay("Accounts")) + dim(f"   ·   {n} saved"))
    info()
    info(IND + border("┌", "┬", "┐"))
    info(line([_cell("", 1, dim),
               _cell("ACCOUNT", w_name, H), _cell("EMAIL", w_mail, H),
               _cell("ORG", w_org, H), _cell("PLAN", w_plan, H),
               _cell("SAVED", w_save, H)]))
    info(IND + border("├", "┼", "┤"))
    for r in rows:
        a = r["active"]
        dot = green("●") if a else dim("○")
        name_c = (lambda s: bold(clay(s))) if a else ink
        text_c = ink if a else dim
        plan_c = green if a else dim
        info(line([" " + dot + " ",
                   _cell(r["name"], w_name, name_c),
                   _cell(r["email"], w_mail, text_c),
                   _cell(r["org"], w_org, text_c),
                   _cell(r["plan"], w_plan, plan_c),
                   _cell(r["saved"], w_save, dim)]))
    info(IND + border("└", "┴", "┘"))
    info()
    info(IND + green("●") + dim(" active") + "    " + dim("○ saved"))
    if not active:
        info()
        warn("active account isn't saved yet — run " + clay("claude-auth add"))
    info()

def cmd_current(args):
    idx = load_index()
    active = active_name(idx)
    oauth, _ = current_identity()
    email = oauth.get("emailAddress")
    org = oauth.get("organizationName")
    info()
    if active:
        p = idx["accounts"].get(active, {})
        info(IND + green("●") + " " + bold(clay(active)))
        info(IND * 2 + ink(email or "?"))
        meta = "  ·  ".join(x for x in [org, p.get("subscriptionType")] if x)
        if meta:
            info(IND * 2 + dim(meta))
    elif email:
        info(IND + yellow("●") + " " + ink(email) + dim("   (not saved)"))
        info(IND * 2 + dim("run ") + clay("claude-auth add") + dim(" to save it"))
    else:
        hint("not logged in")
    info()

def _token_for(name, idx, active):
    """Access token for an account: live blob if active, else its backup."""
    if name == active:
        blob, _ = read_live_credential()
    else:
        raw = kc_read(STORE_SERVICE, name)
        blob = json.loads(raw) if raw else None
    if not blob:
        return None
    return blob.get("claudeAiOauth", {}).get("accessToken")

def _get_usage(name, idx, active, allow_refresh=True):
    """Live usage for an account, caching the result. Refreshes an expired
    *inactive* token once and retries. Returns (normalized, err)."""
    token = _token_for(name, idx, active)
    if not token:
        return None, "no token"
    data, err = fetch_usage(token)
    if err == "expired" and allow_refresh and name != active:
        done, rerr = refresh_stored(name, idx)
        if done:
            token = _token_for(name, idx, active)
            data, err = fetch_usage(token)
        else:
            return None, f"expired ({rerr})"
    if data is None:
        return None, err
    norm = parse_usage(data)
    norm["fetchedAt"] = int(time.time())
    idx["accounts"][name]["usage"] = norm
    return norm, None

def _refresh_usage(name, idx, active):
    """cmd_usage helper: returns {name, live, error}."""
    norm, err = _get_usage(name, idx, active)
    return {"name": name, "live": norm, "error": err}

def cmd_usage(args):
    idx = load_index()
    accts = idx["accounts"]
    if not accts:
        info()
        hint("No saved accounts yet — run " + clay("claude-auth login <name>"))
        info()
        return
    active = active_name(idx)
    names = [args.name] if args.name else sorted(accts)
    if args.name and args.name not in accts:
        die(f"no such account: {bold(args.name)}")

    quiet = getattr(args, "quiet", False)
    if _TTY and not quiet:
        sys.stdout.write(IND + clay("›") + " Fetching usage…")
        sys.stdout.flush()
    with concurrent.futures.ThreadPoolExecutor(max_workers=8) as ex:
        results = {r["name"]: r for r in ex.map(
            lambda n: _refresh_usage(n, idx, active), names)}
    save_index(idx)
    if _TTY and not quiet:
        sys.stdout.write("\r\033[2K")  # return to start, clear the "Fetching" line
        sys.stdout.flush()

    if quiet:
        return
    if args.name:
        _usage_detail(args.name, idx, results[args.name], active)
    else:
        _usage_table(names, idx, results, active)

def _usage_source(name, idx, res):
    """Return (usage_dict, freshness_label) using live result or cache."""
    if res["live"]:
        return res["live"], "live"
    cached = idx["accounts"][name].get("usage")
    if cached:
        return cached, rel_time(cached.get("fetchedAt"))
    return None, res["error"] or "unavailable"

def _win_cell(win, barw=10):
    """Bar + percent + reset-time for one usage window."""
    if not win:
        return bar(None, barw) + "   —"
    pct = win["pct"]
    cell = bar(pct, barw) + " " + sev_color(pct)(pct_str(pct))
    rt = resets_at_str(win.get("resets_at"))
    if rt:
        cell += dim("  " + rt)
    return cell

def _usage_table(names, idx, results, active):
    BARW = 10
    rows = []
    for name in names:
        u, fresh = _usage_source(name, idx, results[name])
        rows.append({
            "name": name, "active": name == active, "fresh": fresh,
            "has": bool(u),
            "sess": _win_cell(u.get("session") if u else None, BARW),
            "week": _win_cell(u.get("week") if u else None, BARW),
        })
    w_name = max(len("ACCOUNT"), max(len(r["name"]) for r in rows))
    w_sess = max(len("SESSION"), max(vlen(r["sess"]) for r in rows))
    w_week = max(len("WEEK"),    max(vlen(r["week"]) for r in rows))
    w_fresh = max(len("UPDATED"), max(len(r["fresh"]) for r in rows))
    widths = [1, w_name, w_sess, w_week, w_fresh]

    def border(l, m, rt):
        return dim(l + m.join("─" * (w + 2) for w in widths) + rt)

    def line(cells):
        return IND + dim("│") + dim("│").join(cells) + dim("│")

    H = lambda s: bold(dim(s))
    info()
    info(IND + bold(clay("Usage")) + dim("   ·   weekly limit is the one that bites"))
    info()
    info(IND + border("┌", "┬", "┐"))
    info(line([_cell("", 1, dim),
               _cell("ACCOUNT", w_name, H),
               _cell("SESSION", w_sess, H),
               _cell("WEEK", w_week, H),
               _cell("UPDATED", w_fresh, H)]))
    info(IND + border("├", "┼", "┤"))
    for r in rows:
        a = r["active"]
        dot = green("●") if a else dim("○")
        name_c = (lambda s: bold(clay(s))) if a else ink
        fresh_c = green if r["fresh"] == "live" else (dim if r["has"] else yellow)
        info(line([" " + dot + " ",
                   _cell(r["name"], w_name, name_c),
                   " " + vpad(r["sess"], w_sess) + " ",
                   " " + vpad(r["week"], w_week) + " ",
                   _cell(r["fresh"], w_fresh, fresh_c)]))
    info(IND + border("└", "┴", "┘"))
    info()
    info(IND + sev_color(10)("█") + dim(" <50%   ") + sev_color(60)("█") +
         dim(" <80%   ") + sev_color(90)("█") + dim(" ≥80%"))
    info()

def _usage_detail(name, idx, res, active):
    u, fresh = _usage_source(name, idx, res)
    p = idx["accounts"][name]
    dot = green("●") if name == active else dim("○")
    info()
    info(IND + dot + " " + bold(clay(name)) + dim("  · " + (p.get("email") or "")))
    info()
    if not u:
        warn(f"usage unavailable ({res['error']})")
        if name != active:
            hint("the stored token may be expired — " + clay(f"claude-auth switch {name}") +
                 dim(" refreshes it"))
        info()
        return
    label_w = 17
    BARW = 20
    def row(label, win):
        if not win:
            info(IND + dim(vpad(label, label_w)) + " " + dim("░" * BARW) + "   —")
            return
        pct = win["pct"]
        info(IND + ink(vpad(label, label_w)) + " " + bar(pct, BARW) + " " +
             sev_color(pct)(pct_str(pct)) +
             dim(f"   resets {resets_at_str(win['resets_at'])}"))
    row("Session (5h)", u.get("session"))
    row("Week (all models)", u.get("week"))
    row("Week (Sonnet)", u.get("week_sonnet"))
    if u.get("week_opus"):
        row("Week (Opus)", u.get("week_opus"))
    info()
    info(IND + dim("updated " + fresh))
    info()

def cmd_refresh(args):
    """Refresh the stored tokens of inactive accounts (keeps backups live)."""
    idx = load_index()
    active = active_name(idx)
    if args.name and args.name not in idx["accounts"]:
        die(f"no such account: {bold(args.name)}")
    names = [args.name] if args.name else sorted(idx["accounts"])
    if not names:
        die("no saved accounts yet")
    info()
    for name in names:
        if name == active:
            info(IND + dim("○ " + name + "  (active — managed live by Claude Code, skipped)"))
            continue
        done, err = refresh_stored(name, idx)
        if done:
            ok(f"Refreshed {bold(name)}")
        else:
            warn(f"{name}: {err}")
    save_index(idx)
    info()

def _maybe_bg_refresh(idx):
    """Spawn a detached usage refresh if the cache is stale (keeps statusline live)."""
    cfg = idx.setdefault("config", {})
    if int(time.time()) - cfg.get("statuslineRefreshAt", 0) < 300:
        return
    cfg["statuslineRefreshAt"] = int(time.time())
    try:
        save_index(idx)
        subprocess.Popen(f"nohup {_bin_path()} usage --quiet >/dev/null 2>&1 &",
                         shell=True, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    except Exception:
        pass

def cmd_statusline(args):
    """Compact one-line status for a Claude Code statusLine command. Network-free."""
    global _TTY
    if not _NO_COLOR and not args.plain:
        _TTY = True   # statusLine output is captured but Claude Code renders ANSI
    # statusLine commands receive session JSON on stdin; drain and ignore it
    try:
        if not sys.stdin.isatty():
            sys.stdin.read()
    except Exception:
        pass
    idx = load_index()
    active = active_name(idx)
    if not active:
        oauth, _ = current_identity()
        print(clay("◆") + " " + dim(oauth.get("emailAddress") or "not logged in"))
        return
    seg = green("●") + " " + bold(clay(active))
    wk = (idx["accounts"][active].get("usage") or {}).get("week")
    if wk and wk.get("pct") is not None:
        pct = wk["pct"]
        seg += dim(" · ") + sev_color(pct)(f"wk {round(pct)}%")
        r = resets_at_str(wk.get("resets_at"))
        if r:
            seg += dim(" · ↺ " + r)
    print(seg)
    if not args.no_refresh:
        _maybe_bg_refresh(idx)

def cmd_switch(args):
    idx = load_index()
    accts = idx["accounts"]
    if not accts:
        die("no saved accounts yet — run " + clay("claude-auth login <name>"))

    name = args.name
    if not name:
        name = _interactive_pick(idx)
        if not name:
            return

    if name not in accts:
        die(f"no such account: {bold(name)}")

    active = active_name(idx)
    if active == name and not args.force:
        info()
        step(f"Already on {bold(clay(name))}")
        info()
        return

    # keep the outgoing account's stored copy fresh (tokens rotate, MCP auth, etc.)
    if active and not args.no_save:
        snapshot_into(active, idx, quiet=True)

    restore(name, idx)
    p = accts[name]
    info()
    ok(f"Switched to {bold(clay(name))}  {dim('· ' + (p.get('email') or ''))}")
    hint("↻ restart Claude Code (and running sessions) to use this account")
    info()

def _interactive_pick(idx):
    accts = sorted(idx["accounts"].items())
    active = active_name(idx)
    w = max(len(n) for n, _ in accts)
    info()
    info(IND + bold(clay("Select an account")))
    info()
    for i, (name, p) in enumerate(accts, 1):
        dot = green("●") if name == active else dim("○")
        info(IND * 2 + cyan(f"{i}") + "  " + dot + " " +
             bold(ink(vpad(name, w))) + "   " + dim(p.get("email") or ""))
    info()
    try:
        choice = input(IND + clay("›") + " ").strip()
    except (EOFError, KeyboardInterrupt):
        info()
        return None
    if not choice:
        return None
    if choice.isdigit() and 1 <= int(choice) <= len(accts):
        return accts[int(choice) - 1][0]
    if choice in idx["accounts"]:
        return choice
    die(f"invalid selection: {choice}")

def cmd_rename(args):
    idx = load_index()
    if args.old not in idx["accounts"]:
        die(f"no such account: {bold(args.old)}")
    if args.new in idx["accounts"]:
        die(f"'{args.new}' already exists")
    raw = kc_read(STORE_SERVICE, args.old)
    if raw is not None:
        kc_write(STORE_SERVICE, args.new, raw, label=f"claude-auth: {args.new}")
        kc_delete(STORE_SERVICE, args.old)
    idx["accounts"][args.new] = idx["accounts"].pop(args.old)
    save_index(idx)
    info()
    ok(f"Renamed {bold(args.old)} {dim('→')} {bold(clay(args.new))}")
    info()

def cmd_remove(args):
    idx = load_index()
    if args.name not in idx["accounts"]:
        die(f"no such account: {bold(args.name)}")
    if active_name(idx) == args.name and not args.force:
        die(f"'{args.name}' is the active account — pass {bold('--force')} to remove it")
    kc_delete(STORE_SERVICE, args.name)
    del idx["accounts"][args.name]
    save_index(idx)
    info()
    ok(f"Removed {bold(args.name)}")
    info()

# ─────────────────────────── auto-switch ──────────────────────────────────

def _as_config(idx):
    cfg = idx.setdefault("config", {}).setdefault("autoswitch", {})
    for k, v in AUTOSWITCH_DEFAULTS.items():
        cfg.setdefault(k, v)
    return cfg

def _usage_pct(name, idx, active, window):
    """Live usage % for `name` on `window` (auto-refreshes if expired). (pct, err)."""
    norm, err = _get_usage(name, idx, active)
    if norm is None:
        return None, err
    w = norm.get(window)
    return (w["pct"] if w else None), None

def _notify(title, msg):
    try:
        subprocess.run(
            ["osascript", "-e",
             f"display notification {json.dumps(msg)} with title {json.dumps(title)}"],
            capture_output=True, timeout=5)
    except Exception:
        pass

def _as_log(msg):
    try:
        os.makedirs(STORE_DIR, exist_ok=True)
        ts = datetime.now().astimezone().strftime("%Y-%m-%d %H:%M:%S")
        with open(os.path.join(STORE_DIR, "autoswitch.log"), "a") as f:
            f.write(f"{ts}  {msg}\n")
    except Exception:
        pass

# ---- settings.json hook management ----

def _bin_path():
    return shutil.which("claude-auth") or os.path.join(HOME, ".local/bin/claude-auth")

def _hook_command(detached):
    base = f"{_bin_path()} autoswitch run --quiet"
    return f"nohup {base} >/dev/null 2>&1 &" if detached else base

# Stop fires when Claude goes idle (detached, zero-latency). SessionStart fires
# as a new session begins (synchronous, so the swap can land before the session
# reads credentials — a best-effort pre-flight switch).
_HOOK_EVENTS = (("Stop", True), ("SessionStart", False))

def _read_settings():
    try:
        with open(SETTINGS) as f:
            return json.load(f)
    except FileNotFoundError:
        return {}
    except json.JSONDecodeError:
        die(f"{SETTINGS} is not valid JSON")

def _write_settings(data):
    os.makedirs(os.path.dirname(SETTINGS), exist_ok=True)
    tmp = SETTINGS + ".claude-auth.tmp"
    with open(tmp, "w") as f:
        json.dump(data, f, indent=2)
    os.replace(tmp, SETTINGS)

def _hook_is_ours(h):
    return isinstance(h, dict) and "claude-auth" in h.get("command", "") \
        and "autoswitch" in h.get("command", "")

def _install_hooks():
    """Install/refresh our Stop + SessionStart hooks. Returns list of new events."""
    s = _read_settings()
    hooks = s.setdefault("hooks", {})
    added = []
    for event, detached in _HOOK_EVENTS:
        lst = hooks.setdefault(event, [])
        found = False
        for group in lst:
            for h in group.get("hooks", []):
                if _hook_is_ours(h):
                    h["command"] = _hook_command(detached)   # refresh path/flags
                    found = True
        if not found:
            lst.append({"hooks": [{"type": "command",
                                   "command": _hook_command(detached)}]})
            added.append(event)
    _write_settings(s)
    return added

def _uninstall_hooks():
    s = _read_settings()
    hooks = s.get("hooks", {})
    if not hooks:
        return
    for event, _ in _HOOK_EVENTS:
        lst = hooks.get(event)
        if not lst:
            continue
        new = []
        for group in lst:
            kept = [h for h in group.get("hooks", []) if not _hook_is_ours(h)]
            if kept:
                group["hooks"] = kept
                new.append(group)
        if new:
            hooks[event] = new
        else:
            hooks.pop(event, None)
    if not hooks:
        s.pop("hooks", None)
    _write_settings(s)

def _hook_installed():
    hooks = _read_settings().get("hooks", {})
    n = 0
    for event, _ in _HOOK_EVENTS:
        for group in hooks.get(event, []):
            if any(_hook_is_ours(h) for h in group.get("hooks", [])):
                n += 1
                break
    return n  # 0, 1, or 2 of our hook points present

# ---- the check itself (invoked by the Stop hook) ----

def _autoswitch_run(args):
    idx = load_index()
    cfg = _as_config(idx)
    if not cfg["enabled"] and not args.force:
        return
    now = int(time.time())
    if not args.force and now - cfg.get("lastCheckAt", 0) < cfg["intervalSec"]:
        return
    cfg["lastCheckAt"] = now
    save_index(idx)

    active = active_name(idx)
    if not active or active not in idx["accounts"]:
        return
    window = args.window or cfg["window"]
    thr = args.threshold if args.threshold is not None else cfg["threshold"]

    cur, err = _usage_pct(active, idx, active, window)
    save_index(idx)
    if cur is None:
        _as_log(f"skip: {active} usage unavailable ({err})")
        if not args.quiet:
            warn(f"usage unavailable for {active} ({err})")
        return
    if cur < thr:
        if not args.quiet:
            info()
            step(f"{bold(active)} at {cur:.0f}% {window} — under {thr}%, no switch")
            info()
        return

    # over threshold → score the other accounts
    scored = []
    for n in idx["accounts"]:
        if n != active:
            pct, _e = _usage_pct(n, idx, active, window)
            scored.append((n, pct))
    save_index(idx)
    eligible = [(n, p) for n, p in scored if p is not None and p < thr]
    if not eligible:
        _as_log(f"{active} at {cur:.0f}% but no account under {thr}% — staying")
        _notify("claude-auth", f"{active} at {cur:.0f}% — all accounts near limit, can't switch")
        if not args.quiet:
            warn(f"{active} at {cur:.0f}% but no account is under {thr}%")
        return

    if cfg["strategy"] == "lowest":
        target = min(eligible, key=lambda x: x[1])[0]
    else:  # round-robin "next"
        order = sorted(idx["accounts"])
        i = order.index(active)
        rotation = order[i + 1:] + order[:i]
        elig = {n for n, _ in eligible}
        target = next((n for n in rotation if n in elig), eligible[0][0])
    tgt_pct = dict(eligible)[target]

    if args.dry_run:
        msg = f"would switch {active} ({cur:.0f}%) → {target} ({tgt_pct:.0f}%)"
        _as_log("dry-run: " + msg)
        info()
        step(msg + dim("  (dry run — no change made)"))
        info()
        return

    snapshot_into(active, idx, quiet=True)
    restore(target, idx)
    _as_log(f"auto-switched {active} ({cur:.0f}%) → {target} ({tgt_pct:.0f}%)")
    _notify("claude-auth",
            f"Switched {active} → {target} ({window} {cur:.0f}%). Restart Claude Code to use it.")
    if not args.quiet:
        info()
        ok(f"Auto-switched {bold(active)} → {bold(clay(target))}  {dim(f'{window} {cur:.0f}%')}")
        hint("↻ restart Claude Code to use the new account")
        info()

def _autoswitch_status(idx, cfg):
    on = cfg["enabled"]
    info()
    info(IND + (green("●") if on else dim("○")) + " " + bold(clay("Auto-switch")) +
         "  " + (green("enabled") if on else dim("disabled")))
    info()
    field = lambda k: dim(vpad(k, 12))
    info(IND * 2 + field("threshold") + " " + ink(f"{cfg['threshold']}%") +
         dim(f"  of {cfg['window']} usage"))
    info(IND * 2 + field("strategy") + " " + ink(cfg["strategy"]) +
         dim("  (next = round-robin · lowest = most headroom)"))
    info(IND * 2 + field("interval") + " " + ink(f"{cfg['intervalSec']}s") +
         dim("  min between checks"))
    n = _hook_installed()
    hook_txt = green("Stop + SessionStart") if n == 2 else \
        (yellow(f"{n}/2 present — re-run `autoswitch on`") if n else red("missing"))
    info(IND * 2 + field("hooks") + " " + hook_txt)
    last = cfg.get("lastCheckAt") or 0
    info(IND * 2 + field("last check") + " " + dim(rel_time(last) if last else "never"))
    info()
    if on:
        hint("runs when Claude goes idle (Stop hook) · a switch applies on next restart")
    else:
        hint("enable with " + clay("claude-auth autoswitch on"))
    info()

def cmd_autoswitch(args):
    if args.action == "run":
        _autoswitch_run(args)
        return
    idx = load_index()
    cfg = _as_config(idx)
    if args.action == "on":
        cfg["enabled"] = True
        if args.threshold is not None:
            cfg["threshold"] = args.threshold
        if args.window:
            cfg["window"] = args.window
        if args.strategy:
            cfg["strategy"] = args.strategy
        if args.interval is not None:
            cfg["intervalSec"] = args.interval
        save_index(idx)
        added = _install_hooks()
        info()
        ok(f"Auto-switch enabled — switch above {bold(str(cfg['threshold']) + '%')} {cfg['window']} usage")
        hint(f"strategy {cfg['strategy']} · checks at most every {cfg['intervalSec']}s when Claude is idle")
        hint("hooks " + ("installed" if added else "refreshed") +
             " in ~/.claude/settings.json " + dim("(Stop = at idle, SessionStart = pre-flight)"))
        hint("SessionStart tries to switch before a new session loads; otherwise a switch applies on restart")
        info()
    elif args.action == "off":
        cfg["enabled"] = False
        save_index(idx)
        _uninstall_hooks()
        info()
        ok("Auto-switch disabled " + dim("(hooks removed)"))
        info()
    else:  # status
        _autoswitch_status(idx, cfg)

# ──────────────────────────────── pool ────────────────────────────────────
#
# `pool` runs a tiny local proxy that all your accounts share. Claude Code is
# pointed at  http://127.0.0.1:<port>  (via ANTHROPIC_BASE_URL in settings.json),
# and every request is forwarded to the real API using one account's token.
# When an account hits its rate limit (HTTP 429) the proxy quietly fails over to
# another account and retries the *same* request — so a running session keeps
# going without a switch or a restart.
#
# Why this is correct and not a hack: the Messages API is stateless. The client
# resends the whole conversation on every turn, so there is no server-side
# session to "move" — any account can serve any turn. The proxy is just a
# load-balancer over stateless requests.
#
# Testing seam: set CLAUDE_AUTH_UPSTREAM_HOST / _PORT / _PLAIN to point the
# forwarder at a fake upstream instead of api.anthropic.com.

def _upstream_host():
    return os.environ.get("CLAUDE_AUTH_UPSTREAM_HOST", "api.anthropic.com")

def _upstream_conn():
    host = _upstream_host()
    if os.environ.get("CLAUDE_AUTH_UPSTREAM_PLAIN"):   # plain HTTP, for tests only
        return http.client.HTTPConnection(
            host, int(os.environ.get("CLAUDE_AUTH_UPSTREAM_PORT", "80")), timeout=300)
    return http.client.HTTPSConnection(
        host, int(os.environ.get("CLAUDE_AUTH_UPSTREAM_PORT", "443")), timeout=300)

def _retry_after_secs(headers):
    """How long to rest an account after a 429, from the response headers."""
    ra = headers.get("Retry-After")
    if ra:
        try:
            return max(5, int(float(ra)))
        except ValueError:
            pass
    for k in ("anthropic-ratelimit-unified-reset",
              "anthropic-ratelimit-unified-5h-reset"):
        v = headers.get(k)
        if v:
            try:
                return max(5, int(float(v) - time.time()))
            except ValueError:
                pass
    return 60

def _pool_log(msg):
    try:
        os.makedirs(STORE_DIR, exist_ok=True)
        ts = datetime.now().astimezone().strftime("%Y-%m-%d %H:%M:%S")
        with open(POOL_LOG, "a") as f:
            f.write(f"{ts}  {msg}\n")
    except Exception:
        pass

def _pool_persist_token(name, token, refresh, expires_in):
    """Best-effort: write a freshly minted token back to the Keychain backup so
    other commands (and a later pool restart) see it too. Never fatal."""
    try:
        raw = kc_read(STORE_SERVICE, name)
        if not raw:
            return
        blob = json.loads(raw)
        cred = blob.setdefault("claudeAiOauth", {})
        cred["accessToken"] = token
        if refresh:
            cred["refreshToken"] = refresh
        if expires_in:
            cred["expiresAt"] = int((time.time() + expires_in) * 1000)
        # write the keychain item directly (avoid kc_write's die-on-error)
        subprocess.run(
            ["security", "add-generic-password", "-U", "-s", STORE_SERVICE,
             "-a", name, "-w", json.dumps(blob), "-l", f"claude-auth: {name}"],
            capture_output=True, text=True)
    except Exception:
        pass


class _Pool:
    """Holds every account's token and decides which one serves each request."""

    def __init__(self, mode):
        self.mode = mode if mode in ("failover", "balance") else "failover"
        self.lock = threading.Lock()
        self.cooldown = {}     # name -> epoch the account is usable again (after a 429)
        self.stats = {}        # name -> {"served", "failover", "last"}
        self.rr = -1           # round-robin cursor (balance mode)
        self.accounts = []     # [{name, token, refresh, expiresAt}], active first
        self.reload()

    def reload(self):
        idx = load_index()
        active = active_name(idx)
        names = sorted(idx["accounts"])
        if active in names:                      # serve from the active account first
            names.remove(active)
            names.insert(0, active)
        accts = []
        for name in names:
            raw = kc_read(STORE_SERVICE, name)
            if not raw:
                continue
            try:
                cred = json.loads(raw).get("claudeAiOauth", {})
            except Exception:
                continue
            if not cred.get("accessToken"):
                continue
            accts.append({
                "name": name,
                "token": cred["accessToken"],
                "refresh": cred.get("refreshToken"),
                "expiresAt": cred.get("expiresAt"),
            })
        with self.lock:
            self.accounts = accts
            self.stats = {a["name"]: self.stats.get(
                a["name"], {"served": 0, "failover": 0, "last": 0}) for a in accts}

    def _by_name(self, name):
        for a in self.accounts:
            if a["name"] == name:
                return a
        return None

    def pick(self, exclude=()):
        """Name of the next account to try, or None if all are on cooldown."""
        now = time.time()
        with self.lock:
            avail = [a for a in self.accounts
                     if a["name"] not in exclude
                     and self.cooldown.get(a["name"], 0) <= now]
            if not avail:
                return None
            if self.mode == "balance":
                self.rr = (self.rr + 1) % len(avail)
                return avail[self.rr]["name"]
            return avail[0]["name"]            # failover: highest-priority healthy one

    def mark_exhausted(self, name, secs):
        with self.lock:
            self.cooldown[name] = time.time() + max(5, secs)
            self.stats.setdefault(name, {"served": 0, "failover": 0, "last": 0})["failover"] += 1
        _pool_log(f"{name}: rate-limited, resting {secs}s")

    def note_served(self, name):
        with self.lock:
            s = self.stats.setdefault(name, {"served": 0, "failover": 0, "last": 0})
            s["served"] += 1
            s["last"] = int(time.time())

    def force_refresh(self, name):
        with self.lock:
            a = self._by_name(name)
            if a:
                a["expiresAt"] = 0            # force token_for() to mint a new one

    def token_for(self, name):
        """A usable access token for `name`, refreshing it first if it's expiring."""
        with self.lock:
            a = self._by_name(name)
            if not a:
                return None
            exp, tok, rt = a.get("expiresAt") or 0, a["token"], a.get("refresh")
        if exp and exp / 1000 > time.time() + 60:
            return tok
        if not rt:
            return tok
        data, _err = refresh_access_token(rt)
        if not data or not data.get("access_token"):
            return tok                        # keep old token; a 401 will retrigger refresh
        new = data["access_token"]
        with self.lock:
            a = self._by_name(name)
            if a:
                a["token"] = new
                if data.get("refresh_token"):
                    a["refresh"] = data["refresh_token"]
                if data.get("expires_in"):
                    a["expiresAt"] = int((time.time() + data["expires_in"]) * 1000)
        _pool_persist_token(name, new, data.get("refresh_token"), data.get("expires_in"))
        return new

    def snapshot(self):
        now = time.time()
        with self.lock:
            return {
                "mode": self.mode,
                "accounts": [{
                    "name": a["name"],
                    "cooldown": max(0, int(self.cooldown.get(a["name"], 0) - now)),
                    "served": self.stats.get(a["name"], {}).get("served", 0),
                    "failover": self.stats.get(a["name"], {}).get("failover", 0),
                } for a in self.accounts],
            }


class PoolHandler(BaseHTTPRequestHandler):
    protocol_version = "HTTP/1.1"
    server_version = f"claude-auth-pool/{__version__}"

    def log_message(self, fmt, *a):          # quiet stderr; everything goes to the log file
        _pool_log(fmt % a)

    def do_GET(self):
        if self.path.startswith("/__pool/"):
            return self._control()
        self._proxy()

    def do_POST(self):   self._proxy()
    def do_PUT(self):    self._proxy()
    def do_PATCH(self):  self._proxy()
    def do_DELETE(self): self._proxy()

    # ---- local control endpoint (never forwarded) ----
    def _control(self):
        self._send_json(200, POOL.snapshot() if POOL else {})

    # ---- the proxy itself ----
    def _proxy(self):
        if POOL is None or not POOL.accounts:
            return self._send_json(503, _err_body("no accounts available to pool"))
        body = self._read_body()
        tried, last = set(), None
        for _ in range(len(POOL.accounts)):
            name = POOL.pick(exclude=tried)
            if not name:
                break
            tried.add(name)
            token = POOL.token_for(name)
            if not token:
                continue
            resp, conn, err = self._send(token, body)
            if err:
                last = ("err", err)
                continue
            if resp.status in (401, 403):    # bad/expired token → refresh once, retry same acct
                self._drain(resp, conn)
                POOL.force_refresh(name)
                resp, conn, err = self._send(POOL.token_for(name), body)
                if err:
                    last = ("err", err)
                    continue
            if resp.status == 429:           # rate-limited → rest this account, fail over
                POOL.mark_exhausted(name, _retry_after_secs(resp.headers))
                self._drain(resp, conn)
                last = ("429", name)
                continue
            POOL.note_served(name)           # success (or a real API error) → stream it back
            self._stream(resp, name)
            self._close(conn)
            return
        self._all_busy(last)

    def _send(self, token, body):
        try:
            conn = _upstream_conn()
            conn.request(self.command, self.path, body=body,
                         headers=self._upstream_headers(token))
            return conn.getresponse(), conn, None
        except Exception as e:
            return None, None, str(e)

    def _upstream_headers(self, token):
        h = {}
        for k in self.headers.keys():        # pass Claude Code's own headers through…
            lk = k.lower()
            if lk in _HOP_BY_HOP or lk in ("host", "authorization", "content-length"):
                continue
            h[k] = self.headers[k]
        h["Host"] = _upstream_host()         # …but swap in our host + chosen account's token
        h["Authorization"] = f"Bearer {token}"
        return h

    def _stream(self, resp, name):
        """Relay the upstream response, byte for byte, flushing as it arrives (SSE-safe)."""
        self.send_response(resp.status)
        for k, v in resp.getheaders():
            if k.lower() in _HOP_BY_HOP or k.lower() in ("content-length", "connection"):
                continue
            self.send_header(k, v)
        self.send_header("X-Claude-Auth-Account", name)   # which account served this
        self.send_header("Connection", "close")
        self.end_headers()
        self.close_connection = True
        try:
            while True:
                chunk = resp.read(65536)
                if not chunk:
                    break
                self.wfile.write(chunk)
                self.wfile.flush()
        except Exception:
            pass

    # ---- small helpers ----
    def _read_body(self):
        n = int(self.headers.get("Content-Length") or 0)
        return self.rfile.read(n) if n > 0 else b""

    def _drain(self, resp, conn):
        try:
            resp.read()
        except Exception:
            pass
        self._close(conn)

    def _close(self, conn):
        try:
            conn.close()
        except Exception:
            pass

    def _send_json(self, code, obj):
        body = json.dumps(obj).encode()
        self.send_response(code)
        self.send_header("Content-Type", "application/json")
        self.send_header("Content-Length", str(len(body)))
        self.send_header("Connection", "close")
        self.end_headers()
        self.close_connection = True
        try:
            self.wfile.write(body)
        except Exception:
            pass

    def _all_busy(self, last):
        if last and last[0] == "429":
            self._send_json(429, _err_body(
                "all pooled accounts are at their rate limit — try again soon"))
        else:
            detail = last[1] if last else "unknown error"
            self._send_json(502, _err_body(f"pool could not reach the API ({detail})"))


def _err_body(message):
    return {"type": "error",
            "error": {"type": "claude_auth_pool_error", "message": message}}


# ─────────────────────── pool: daemon + control commands ───────────────────

def _pool_pid():
    """Return the live daemon's pid, or None (cleaning up a stale pid file)."""
    try:
        with open(POOL_PID) as f:
            pid = int(f.read().strip())
    except (FileNotFoundError, ValueError):
        return None
    try:
        os.kill(pid, 0)
    except (ProcessLookupError, PermissionError):
        try:
            os.remove(POOL_PID)
        except OSError:
            pass
        return None
    return pid

def _pool_read_state():
    try:
        with open(POOL_STATE) as f:
            return json.load(f)
    except (FileNotFoundError, json.JSONDecodeError):
        return {}

def _pool_write_state(d):
    os.makedirs(STORE_DIR, exist_ok=True)
    tmp = POOL_STATE + ".tmp"
    with open(tmp, "w") as f:
        json.dump(d, f, indent=2)
    os.replace(tmp, POOL_STATE)

def _wire_base_url(port):
    """Point Claude Code at the pool by setting env.ANTHROPIC_BASE_URL in settings."""
    s = _read_settings()
    env = s.setdefault("env", {})
    url = f"http://127.0.0.1:{port}"
    prev = env.get("ANTHROPIC_BASE_URL")
    if prev and prev != url and not prev.startswith("http://127.0.0.1:"):
        st = _pool_read_state()
        st["prevBaseUrl"] = prev               # remember it so `stop` can restore it
        _pool_write_state(st)
        warn(f"replacing existing ANTHROPIC_BASE_URL ({prev}) — restored on `pool stop`")
    env["ANTHROPIC_BASE_URL"] = url
    _write_settings(s)

def _unwire_base_url():
    s = _read_settings()
    env = s.get("env")
    if not isinstance(env, dict):
        return
    cur = env.get("ANTHROPIC_BASE_URL", "")
    if not cur.startswith("http://127.0.0.1:"):
        return                                 # not ours — leave the user's value alone
    prev = _pool_read_state().get("prevBaseUrl")
    if prev:
        env["ANTHROPIC_BASE_URL"] = prev
    else:
        del env["ANTHROPIC_BASE_URL"]
        if not env:
            s.pop("env", None)
    _write_settings(s)

def _pool_wait_health(port, timeout=6.0):
    deadline = time.time() + timeout
    url = f"http://127.0.0.1:{port}/__pool/health"
    while time.time() < deadline:
        try:
            with urllib.request.urlopen(url, timeout=1) as r:
                if r.status == 200:
                    return True
        except Exception:
            time.sleep(0.15)
    return False

def _pool_serve(args):
    """The daemon: bind the proxy and serve until SIGTERM. Spawned by `pool start`."""
    global POOL
    POOL = _Pool(args.mode or "failover")
    if not POOL.accounts:
        _pool_log("no accounts to serve; exiting")
        die("no accounts available to pool")
    port = args.port or DEFAULT_POOL_PORT
    try:
        httpd = ThreadingHTTPServer(("127.0.0.1", port), PoolHandler)
    except OSError as e:
        die(f"could not bind 127.0.0.1:{port} — {e}")
    httpd.daemon_threads = True
    try:
        with open(POOL_PID, "w") as f:
            f.write(str(os.getpid()))
    except OSError:
        pass

    def _bye(*_):
        threading.Thread(target=httpd.shutdown, daemon=True).start()
    signal.signal(signal.SIGTERM, _bye)
    signal.signal(signal.SIGINT, _bye)

    _pool_log(f"serving 127.0.0.1:{port} mode={POOL.mode} "
              f"accounts={[a['name'] for a in POOL.accounts]}")
    httpd.serve_forever()
    _pool_log("stopped")

def _pool_start(args):
    idx = load_index()
    n = len(idx["accounts"])
    if n == 0:
        die("no saved accounts — run " + clay("claude-auth login") + " or " + clay("add") + " first")
    pid = _pool_pid()
    if pid:
        die(f"pool already running (pid {pid}) — run " + clay("claude-auth pool stop") + " first")
    port = args.port or DEFAULT_POOL_PORT
    mode = args.mode or "failover"
    info()
    if n == 1:
        warn("only 1 account saved — the pool needs 2+ to fail over")
    step(f"Starting pool on {clay(f'127.0.0.1:{port}')} {dim('· mode ' + mode)}")
    logf = open(POOL_LOG, "a")
    subprocess.Popen([_bin_path(), "pool", "serve", "--port", str(port), "--mode", mode],
                     stdout=logf, stderr=subprocess.STDOUT, start_new_session=True)
    if not _pool_wait_health(port):
        die("pool did not come up — check " + POOL_LOG)
    _pool_write_state({"port": port, "mode": mode, "startedAt": int(time.time())})
    if not args.no_wire:
        _wire_base_url(port)
        ok("Pool is live " + dim("· Claude Code will use it on next start"))
        hint("wired " + ink("ANTHROPIC_BASE_URL") + " into ~/.claude/settings.json")
    else:
        ok(f"Pool is live on {clay(f'http://127.0.0.1:{port}')}")
        hint("point Claude Code at it:  " +
             clay(f"export ANTHROPIC_BASE_URL=http://127.0.0.1:{port}"))
    hint("stop anytime with " + clay("claude-auth pool stop"))
    info()

def _pool_stop(args):
    pid = _pool_pid()
    _unwire_base_url()
    info()
    if not pid:
        hint("pool not running " + dim("(settings.json restored)"))
        info()
        return
    try:
        os.kill(pid, signal.SIGTERM)
    except ProcessLookupError:
        pass
    for _ in range(20):                        # wait up to ~2s for a clean exit
        if not _pool_pid():
            break
        time.sleep(0.1)
    try:
        os.remove(POOL_PID)
    except OSError:
        pass
    ok("Pool stopped " + dim("(settings.json restored)"))
    hint("↻ restart Claude Code to stop using the pool")
    info()

def _pool_status(args):
    pid = _pool_pid()
    st = _pool_read_state()
    info()
    info(IND + bold(clay("Pool")) + dim("   ·   shared multi-account proxy"))
    info()
    if not pid:
        info(IND + dim("○") + " " + dim("not running"))
        hint("start with " + clay("claude-auth pool start"))
        info()
        return
    port = st.get("port", DEFAULT_POOL_PORT)
    info(IND + green("●") + " running   " +
         dim(f"pid {pid} · 127.0.0.1:{port} · mode {st.get('mode', '?')}"))
    snap = None
    try:
        with urllib.request.urlopen(f"http://127.0.0.1:{port}/__pool/health", timeout=2) as r:
            snap = json.loads(r.read().decode())
    except Exception:
        pass
    if snap and snap.get("accounts"):
        info()
        w = max(len(a["name"]) for a in snap["accounts"])
        for a in snap["accounts"]:
            cd = a["cooldown"]
            state = green("ready") if cd == 0 else yellow(f"resting {cd}s")
            info(IND * 2 + ink(vpad(a["name"], w)) + "  " + state +
                 dim(f"   served {a['served']} · failovers {a['failover']}"))
    wired = (_read_settings().get("env") or {}).get("ANTHROPIC_BASE_URL", "")
    info()
    if wired.startswith("http://127.0.0.1:"):
        info(IND * 2 + green("✓") + dim(" wired into settings.json"))
    else:
        info(IND * 2 + yellow("!") + dim(" not wired — Claude Code won't use it (pool start --no-wire?)"))
    info()

def cmd_pool(args):
    action = args.action or "status"
    if action == "serve":
        _pool_serve(args)
    elif action == "start":
        _pool_start(args)
    elif action == "stop":
        _pool_stop(args)
    else:
        _pool_status(args)

# ─────────────────────────────── doctor ───────────────────────────────────

# ──────────────────────────── self-update ─────────────────────────────────

def _version_tuple(s):
    """Best-effort parse of a dotted version string into a comparable tuple."""
    parts = []
    for chunk in str(s).split("."):
        digits = "".join(ch for ch in chunk if ch.isdigit())
        parts.append(int(digits) if digits else 0)
    return tuple(parts) or (0,)

def fetch_remote_script(timeout=10):
    """Download the latest bin/claude-auth from GitHub. Returns (text, err)."""
    req = urllib.request.Request(RAW_SCRIPT_URL, headers={
        "User-Agent": f"claude-auth/{__version__}",
        "Cache-Control": "no-cache",
    })
    try:
        with urllib.request.urlopen(req, timeout=timeout) as r:
            return r.read().decode("utf-8"), None
    except urllib.error.HTTPError as e:
        return None, f"http {e.code}"
    except Exception as e:
        return None, str(e).split("]")[-1].strip()[:50] or "network error"

_VERSION_RE = re.compile(r'''^__version__\s*=\s*["']([^"']+)["']''', re.M)

def parse_script_version(text):
    """Pull the __version__ string out of a claude-auth script body."""
    m = _VERSION_RE.search(text or "")
    return m.group(1) if m else None

def _self_path():
    """Absolute path of the running claude-auth script (symlinks resolved)."""
    return os.path.realpath(os.path.abspath(__file__))

def cmd_update(args):
    """Download the latest script from GitHub and replace this file in place."""
    info()
    info(IND + bold(clay("Update")) + dim("   ·   " + REPO))
    info()

    text, err = fetch_remote_script()
    if err:
        die(f"couldn't reach GitHub: {err}")
    remote = parse_script_version(text)
    if not remote:
        die("couldn't read the version of the downloaded script — aborting")
    local = __version__
    newer = _version_tuple(remote) > _version_tuple(local)
    same  = _version_tuple(remote) == _version_tuple(local)

    # --check: report only, never write
    if getattr(args, "check", False):
        if newer:
            info(IND + yellow("●") + " update available  " +
                 dim(f"v{local} → ") + bold(green(f"v{remote}")))
            info(IND * 2 + dim("run ") + clay("claude-auth update") + dim(" to install"))
        elif same:
            ok(f"up to date  (v{local})")
        else:
            ok(f"you're ahead of GitHub  (local v{local} · remote v{remote})")
        info()
        return

    if same and not args.force:
        ok(f"already up to date  (v{local})")
        hint("re-run with " + clay("--force") + " to reinstall anyway")
        info()
        return
    if not newer and not same and not args.force:
        warn(f"local v{local} is newer than GitHub v{remote} — nothing to do")
        hint("pass " + clay("--force") + " to overwrite with the GitHub version")
        info()
        return

    # Never overwrite ourselves with something that isn't valid Python.
    try:
        compile(text, "<remote claude-auth>", "exec")
    except SyntaxError as e:
        die(f"downloaded script failed to parse ({e}) — refusing to install")

    target = _self_path()
    tmp = target + ".update.tmp"
    try:
        with open(tmp, "w", encoding="utf-8") as f:
            f.write(text)
        os.chmod(tmp, 0o755)
        os.replace(tmp, target)  # atomic on the same filesystem
    except PermissionError:
        try: os.remove(tmp)
        except OSError: pass
        die(f"no write permission for {target}\n" +
            IND + dim("re-run ") + clay("./install.sh") + dim(" from the repo, or use sudo"))
    except Exception as e:
        try: os.remove(tmp)
        except OSError: pass
        die(f"update failed: {e}")

    info(IND + green("✓") + " Updated  " + dim(f"v{local} → ") + bold(green(f"v{remote}")))
    info(IND * 2 + dim(target))
    info()

def cmd_doctor(args):
    idx = load_index()
    counts = {"ok": 0, "warn": 0, "fail": 0}

    def check(state, label, detail=""):
        mark = {"ok": green("✓"), "warn": yellow("!"), "fail": red("✗")}[state]
        counts[state] += 1
        line = IND + mark + " " + label
        if detail:
            line += dim("   " + detail)
        info(line)

    info()
    info(IND + bold(clay("Doctor")) + dim("   ·   checking your setup"))
    info()

    # platform
    check("ok" if sys.platform == "darwin" else "fail", "macOS",
          sys.platform if sys.platform != "darwin" else "")

    # claude CLI (needed for `login`)
    cpath = shutil.which("claude")
    if cpath:
        ver = subprocess.run(["claude", "--version"], capture_output=True, text=True).stdout.strip()
        check("ok", "claude CLI", ver or cpath)
    else:
        check("warn", "claude CLI", "not on PATH (only `login` needs it)")

    # claude-auth itself on PATH (hooks + statusline call it by name)
    capath = shutil.which("claude-auth")
    check("ok" if capath else "warn", "claude-auth on PATH",
          capath or "not found — hooks/statusline may fail")

    # latest version (best-effort — skipped silently when offline)
    rtext, rerr = fetch_remote_script(timeout=5)
    if not rerr:
        remote = parse_script_version(rtext)
        if remote and _version_tuple(remote) > _version_tuple(__version__):
            check("warn", "version",
                  f"v{__version__} — update available (v{remote}): run `claude-auth update`")
        elif remote:
            check("ok", "version", f"v{__version__} (latest)")

    # keychain access
    blob, acct = read_live_credential()
    check("ok" if blob else "fail", "Keychain access",
          f"live credential present ({acct})" if blob else "no live credential — run `claude auth login`")

    # saved accounts
    n = len(idx["accounts"])
    check("ok" if n else "warn", f"{n} account(s) saved",
          "" if n else "run `claude-auth add` or `login`")

    # active account
    active = active_name(idx)
    check("ok" if active else "warn", "active account",
          active or "current login isn't saved as a profile (run `claude-auth add`)")

    # autoswitch + hooks
    cfg = _as_config(idx)
    if cfg["enabled"]:
        hn = _hook_installed()
        check("ok" if hn == 2 else "warn", "autoswitch",
              "Stop + SessionStart hooks present" if hn == 2
              else f"enabled but {hn}/2 hooks — re-run `claude-auth autoswitch on`")
    else:
        check("ok", "autoswitch", "disabled")

    # statusline wiring (informational)
    slcmd = (_read_settings().get("statusLine") or {}).get("command", "")
    if "claude-auth statusline" in slcmd:
        check("ok", "statusline", "wired into settings.json")

    # pool proxy (informational — only shown when running or wired)
    ppid = _pool_pid()
    pwired = (_read_settings().get("env") or {}).get("ANTHROPIC_BASE_URL", "")
    pmine = pwired.startswith("http://127.0.0.1:")
    if ppid and pmine:
        check("ok", "pool", f"running (pid {ppid}) and wired into settings.json")
    elif ppid and not pmine:
        check("warn", "pool", "running but not wired — `claude-auth pool start` to wire it")
    elif pmine and not ppid:
        check("warn", "pool",
              "settings.json points at a pool that isn't running — `claude-auth pool stop`")

    # per-account token freshness (offline — reads keychain, no network)
    if idx["accounts"]:
        info()
        info(IND + dim("accounts:"))
        for name in sorted(idx["accounts"]):
            raw = kc_read(STORE_SERVICE, name)
            if raw is None:
                check("warn", name, "backup missing from Keychain")
                continue
            cred = json.loads(raw).get("claudeAiOauth", {})
            exp = cred.get("expiresAt")
            fresh = exp and exp / 1000 > time.time()
            if name == active:
                check("ok", name, "active (managed live by Claude Code)")
            elif fresh:
                check("ok", name, "token valid")
            else:
                check("warn", name, "token stale — refreshes on next use, or `claude-auth refresh " + name + "`")

    info()
    summary = f"{counts['ok']} ok"
    if counts["warn"]:
        summary += f" · {counts['warn']} warning(s)"
    if counts["fail"]:
        summary += f" · {counts['fail']} error(s)"
    tone = red if counts["fail"] else (yellow if counts["warn"] else green)
    info(IND + tone("●") + " " + tone(summary))
    info()

# ──────────────────────────── shell completion ────────────────────────────

_BASH_COMPLETION = r'''
_claude_auth() {
  local cur prev cmds sub
  cur="${COMP_WORDS[COMP_CWORD]}"
  cmds="login add list ls switch usage autoswitch pool refresh statusline current whoami rename remove rm doctor update completion help"
  if [ "$COMP_CWORD" -eq 1 ]; then
    COMPREPLY=( $(compgen -W "$cmds" -- "$cur") ); return
  fi
  sub="${COMP_WORDS[1]}"
  case "$sub" in
    switch|usage|rename|remove|rm|refresh)
      COMPREPLY=( $(compgen -W "$(claude-auth completion --names 2>/dev/null)" -- "$cur") ) ;;
    autoswitch) COMPREPLY=( $(compgen -W "on off status run" -- "$cur") ) ;;
    pool) COMPREPLY=( $(compgen -W "start stop status" -- "$cur") ) ;;
    update) COMPREPLY=( $(compgen -W "--check --force" -- "$cur") ) ;;
    completion) COMPREPLY=( $(compgen -W "bash zsh" -- "$cur") ) ;;
  esac
}
complete -F _claude_auth claude-auth
'''.strip()

_ZSH_COMPLETION = r'''
_claude_auth() {
  local -a cmds
  cmds=(login add list ls switch usage autoswitch pool refresh statusline current whoami rename remove rm doctor update completion)
  if (( CURRENT == 2 )); then compadd -- $cmds; return; fi
  case "${words[2]}" in
    switch|usage|rename|remove|rm|refresh)
      compadd -- ${(f)"$(claude-auth completion --names 2>/dev/null)"} ;;
    autoswitch) compadd -- on off status run ;;
    pool) compadd -- start stop status ;;
    update) compadd -- --check --force ;;
    completion) compadd -- bash zsh ;;
  esac
}
compdef _claude_auth claude-auth
'''.strip()

_COMMAND_REFERENCE = [
    ("ACCOUNTS", [
        ("login",   "[name]",      "Sign in fresh and save as a profile", "--email --console --sso"),
        ("add",     "[name]",      "Save the currently logged-in account", "--force"),
        ("switch",  "[name]",      "Switch to a saved account", "--force --no-save"),
        ("list",    "",            "List saved accounts", "alias: ls"),
        ("current", "",            "Show the active account", "alias: whoami"),
        ("rename",  "<old> <new>", "Rename a saved profile", ""),
        ("remove",  "<name>",      "Delete a saved profile", "--force · alias: rm"),
    ]),
    ("USAGE & LIMITS", [
        ("usage",      "[name]",   "Show rate-limit usage across accounts", "--quiet"),
        ("refresh",    "[name]",   "Refresh stored tokens of inactive accounts", ""),
        ("autoswitch", "[on|off]", "Auto-switch when usage gets high", "status|run · --threshold --window --strategy"),
        ("pool",       "[start|stop]", "Pool all accounts behind one auto-failover proxy", "status · --port --mode --no-wire"),
    ]),
    ("SETUP & INTEGRATION", [
        ("statusline", "",         "Compact status line for Claude Code", "--plain"),
        ("completion", "[bash|zsh]", "Output a shell-completion script", ""),
        ("doctor",     "",         "Health-check your setup", ""),
        ("update",     "",         "Update claude-auth to the latest version", "--check --force"),
    ]),
    ("MISC", [
        ("commands",   "",         "Show this command reference", ""),
        ("--help, -h", "",         "Full help screen", "with a cat 🐈"),
        ("--version",  "",         "Print the version", "alias: -V"),
    ]),
]

def cmd_commands(args):
    rows = [r for _, group in _COMMAND_REFERENCE for r in group]
    nw = max(len(r[0]) for r in rows)
    aw = max(len(r[1]) for r in rows)
    info()
    info(IND + bold(clay("Commands")) + dim(f"   ·   claude-auth v{__version__}"))
    for title, group in _COMMAND_REFERENCE:
        info()
        info(IND + bold(clay(title)))
        for name, a, desc, extra in group:
            line = IND * 2 + bold(ink(vpad(name, nw))) + "  " + dim(vpad(a, aw)) + "  " + desc
            if extra:
                line += dim("   " + extra)
            info(line)
    info()
    info(IND + dim("docs   ") + cyan(REPO))
    info()

def cmd_completion(args):
    if args.names:
        print("\n".join(sorted(load_index()["accounts"])))
        return
    if args.shell == "zsh":
        print(_ZSH_COMPLETION)
    elif args.shell == "bash":
        print(_BASH_COMPLETION)
    else:
        info()
        info(IND + bold(clay("Shell completion")) + dim("   ·   tab-complete commands & account names"))
        info()
        info(IND + dim("zsh") + "  — add to " + ink("~/.zshrc") + ":")
        info(IND * 2 + clay('eval "$(claude-auth completion zsh)"'))
        info()
        info(IND + dim("bash") + " — add to " + ink("~/.bashrc") + ":")
        info(IND * 2 + clay('eval "$(claude-auth completion bash)"'))
        info()

# ──────────────────────────── arg parsing ─────────────────────────────────

class BrandParser(argparse.ArgumentParser):
    def format_help(self):
        return render_help() + "\n"
    def print_help(self, file=None):
        _play_cat()
        (file or sys.stdout).write(self.format_help())
    def error(self, message):
        die(message + dim("   ·   see ") + clay("claude-auth --help"), code=2)

def build_parser():
    p = BrandParser(prog="claude-auth", add_help=True,
                    description="Switch between multiple Claude Code accounts (macOS).")
    p.add_argument("-V", "--version", action="version",
                   version=f"claude-auth {__version__}")
    sub = p.add_subparsers(dest="cmd")

    lg = sub.add_parser("login", help="sign in fresh and save the result as a profile")
    lg.add_argument("name", nargs="?", help="profile name (default: email prefix)")
    lg.add_argument("--email", help="pre-populate the email on the login page")
    lg.add_argument("--console", action="store_true",
                    help="use Anthropic Console (API billing) instead of subscription")
    lg.add_argument("--sso", action="store_true", help="force the SSO login flow")
    lg.set_defaults(func=cmd_login)

    a = sub.add_parser("add", help="save the current account as a named profile")
    a.add_argument("name", nargs="?", help="profile name (default: email prefix)")
    a.add_argument("-f", "--force", action="store_true", help="overwrite if exists")
    a.set_defaults(func=cmd_add)

    for alias in ("list", "ls"):
        l = sub.add_parser(alias, help="list saved accounts")
        l.set_defaults(func=cmd_list)

    s = sub.add_parser("switch", help="switch to a saved account")
    s.add_argument("name", nargs="?", help="account to switch to (interactive if omitted)")
    s.add_argument("-f", "--force", action="store_true", help="switch even if already active")
    s.add_argument("--no-save", action="store_true",
                   help="don't refresh the outgoing account's stored copy")
    s.set_defaults(func=cmd_switch)

    for alias in ("current", "whoami"):
        c = sub.add_parser(alias, help="show the active account")
        c.set_defaults(func=cmd_current)

    u = sub.add_parser("usage", help="show rate-limit usage for your accounts")
    u.add_argument("name", nargs="?", help="account to detail (default: all)")
    u.add_argument("--quiet", action="store_true", help="fetch & cache silently (no output)")
    u.set_defaults(func=cmd_usage)

    rf = sub.add_parser("refresh", help="refresh stored tokens of inactive accounts")
    rf.add_argument("name", nargs="?", help="account to refresh (default: all inactive)")
    rf.set_defaults(func=cmd_refresh)

    sl = sub.add_parser("statusline", help="compact status line for Claude Code")
    sl.add_argument("--plain", action="store_true", help="no color")
    sl.add_argument("--no-refresh", action="store_true",
                    help="don't trigger a background usage refresh")
    sl.set_defaults(func=cmd_statusline)

    asw = sub.add_parser("autoswitch", help="auto-switch when usage gets high")
    asw.add_argument("action", nargs="?", default="status",
                     choices=["on", "off", "status", "run"])
    asw.add_argument("--threshold", type=int, help="switch above this usage %% (default 90)")
    asw.add_argument("--window", choices=["session", "week"],
                     help="which limit to watch (default session)")
    asw.add_argument("--strategy", choices=["next", "lowest"],
                     help="next = round-robin, lowest = most headroom")
    asw.add_argument("--interval", type=int, help="min seconds between checks (default 120)")
    asw.add_argument("--quiet", action="store_true", help="suppress output (used by the hook)")
    asw.add_argument("--force", action="store_true", help="ignore enabled/throttle and run now")
    asw.add_argument("--dry-run", action="store_true", help="decide and report, but don't switch")
    asw.set_defaults(func=cmd_autoswitch)

    pl = sub.add_parser("pool", help="pool all accounts behind one auto-failover proxy")
    pl.add_argument("action", nargs="?", default="status",
                    choices=["start", "stop", "status", "serve"])
    pl.add_argument("--port", type=int,
                    help=f"port to listen on (default {DEFAULT_POOL_PORT})")
    pl.add_argument("--mode", choices=["failover", "balance"],
                    help="failover = move only when rate-limited; balance = spread every request")
    pl.add_argument("--no-wire", action="store_true",
                    help="don't edit settings.json; just print the URL to set yourself")
    pl.set_defaults(func=cmd_pool)

    rn = sub.add_parser("rename", help="rename a saved account")
    rn.add_argument("old")
    rn.add_argument("new")
    rn.set_defaults(func=cmd_rename)

    for alias in ("remove", "rm"):
        rm = sub.add_parser(alias, help="delete a saved account")
        rm.add_argument("name")
        rm.add_argument("-f", "--force", action="store_true",
                        help="remove even if it's the active account")
        rm.set_defaults(func=cmd_remove)

    dr = sub.add_parser("doctor", help="health-check your setup")
    dr.set_defaults(func=cmd_doctor)

    cm = sub.add_parser("commands", help="show all commands (cheat sheet)")
    cm.set_defaults(func=cmd_commands)

    comp = sub.add_parser("completion", help="output shell completion (bash|zsh)")
    comp.add_argument("shell", nargs="?", choices=["bash", "zsh"])
    comp.add_argument("--names", action="store_true", help=argparse.SUPPRESS)
    comp.set_defaults(func=cmd_completion)

    up = sub.add_parser("update", help="update claude-auth to the latest version")
    up.add_argument("--check", action="store_true", help="only check; don't install")
    up.add_argument("--force", action="store_true", help="reinstall even if already up to date")
    up.set_defaults(func=cmd_update)

    return p

def main():
    if sys.platform != "darwin":
        die("claude-auth currently supports macOS only (uses the login Keychain).")
    parser = build_parser()
    args = parser.parse_args()
    if not getattr(args, "func", None):
        _play_cat()
        print(render_help())
        sys.exit(0)
    args.func(args)

if __name__ == "__main__":
    main()
