#!/usr/bin/env python3
"""
claude-auth вҖ” switch between multiple Claude Code accounts on one machine.

Like `gh auth switch`, but for Claude Code. Snapshots the currently logged-in
account (Keychain credential blob + ~/.claude.json identity) into a named
profile, and restores any saved profile on demand.

macOS only (uses the login Keychain via the `security` CLI). Secret tokens stay
in the Keychain; only non-secret identity metadata is kept in a plaintext index.
"""

import sys
import os
import re
import json
import time
import shutil
import getpass
import subprocess
import argparse
import urllib.request
import urllib.error
import concurrent.futures
from datetime import datetime, timezone

__version__ = "1.1.0"

API_USAGE = "https://api.anthropic.com/api/oauth/usage"
OAUTH_BETA = "oauth-2025-04-20"
ANTHROPIC_VERSION = "2023-06-01"

HOME = os.path.expanduser("~")
CLAUDE_JSON = os.path.join(HOME, ".claude.json")
STORE_DIR = os.path.join(HOME, ".claude-accounts")
INDEX_PATH = os.path.join(STORE_DIR, "accounts.json")

LIVE_SERVICE = "Claude Code-credentials"   # the item Claude Code itself reads
STORE_SERVICE = "claude-auth-store"         # our namespaced backups, per account

REPO = "github.com/vishalmakwana111/claude-auth"

# в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ theme в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

_NO_COLOR = bool(os.environ.get("NO_COLOR"))
_TTY = sys.stdout.isatty() and not _NO_COLOR

# Claude's warm "clay" palette (truecolor 24-bit)
CLAY      = (204, 120, 92)     # primary brand
CLAY_LITE = (236, 170, 120)
CLAY_DARK = (150, 78, 58)
INK       = (236, 223, 196)    # warm off-white
MUTE      = (140, 140, 140)
OK        = (122, 192, 140)
WARN      = (228, 182, 86)
ERR       = (226, 110, 102)
ACCENT    = (140, 174, 244)    # soft blue for numbers / links

def _fg(rgb, s):
    if not _TTY:
        return s
    r, g, b = rgb
    return f"\033[38;2;{r};{g};{b}m{s}\033[0m"

def _sgr(code, s):
    return f"\033[{code}m{s}\033[0m" if _TTY else s

def bold(s):   return _sgr("1", s)
def dim(s):    return _fg(MUTE, s)
def clay(s):   return _fg(CLAY, s)
def green(s):  return _fg(OK, s)
def red(s):    return _fg(ERR, s)
def yellow(s): return _fg(WARN, s)
def cyan(s):   return _fg(ACCENT, s)
def ink(s):    return _fg(INK, s)

_ANSI_RE = re.compile(r"\033\[[0-9;]*m")
def vlen(s):
    """Visible width, ignoring ANSI escapes."""
    return len(_ANSI_RE.sub("", s))

def vpad(s, width, align="left"):
    pad = max(0, width - vlen(s))
    return (" " * pad + s) if align == "right" else (s + " " * pad)

def _lerp(a, b, t):
    return tuple(round(a[i] + (b[i] - a[i]) * t) for i in range(3))

def gradient(text, c1, c2):
    """Horizontal color sweep c1 вҶ’ c2 across the characters of `text`."""
    if not _TTY:
        return text
    n = max(1, len(text) - 1)
    return "".join(_fg(_lerp(c1, c2, i / n), ch) for i, ch in enumerate(text))

def term_width():
    try:
        return shutil.get_terminal_size((80, 24)).columns
    except Exception:
        return 80

def rel_time(ts):
    """Human 'time ago' from a unix-seconds timestamp."""
    if not ts:
        return "вҖ”"
    d = int(time.time()) - int(ts)
    if d < 0:
        d = 0
    if d < 60:
        return "just now"
    for unit, secs in (("d", 86400), ("h", 3600), ("m", 60)):
        if d >= secs:
            return f"{d // secs}{unit} ago"
    return "just now"

# в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ usage / limits в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

def fetch_usage(access_token, timeout=8):
    """GET /api/oauth/usage. Returns (data, None) or (None, error)."""
    req = urllib.request.Request(API_USAGE, headers={
        "Authorization": f"Bearer {access_token}",
        "anthropic-beta": OAUTH_BETA,
        "anthropic-version": ANTHROPIC_VERSION,
        "User-Agent": f"claude-auth/{__version__}",
    })
    try:
        with urllib.request.urlopen(req, timeout=timeout) as r:
            return json.loads(r.read().decode()), None
    except urllib.error.HTTPError as e:
        return None, ("expired" if e.code == 401 else f"http {e.code}")
    except Exception as e:
        return None, str(e).split("]")[-1].strip()[:40] or "network error"

def parse_usage(d):
    """Normalize the API response to the windows we display."""
    def win(key):
        w = d.get(key) or {}
        u = w.get("utilization")
        if u is None:
            return None
        return {"pct": float(u), "resets_at": w.get("resets_at")}
    return {
        "session": win("five_hour"),
        "week": win("seven_day"),
        "week_sonnet": win("seven_day_sonnet"),
        "week_opus": win("seven_day_opus"),
    }

def sev_color(pct):
    if pct is None:
        return dim
    return green if pct < 50 else (yellow if pct < 80 else red)

def bar(pct, width=12):
    """Colored utilization bar; visible width is always `width`."""
    if pct is None:
        return dim("в–‘" * width)
    p = max(0.0, min(100.0, pct))
    filled = round(width * p / 100)
    return sev_color(p)("в–Ҳ" * filled) + dim("в–‘" * (width - filled))

def pct_str(pct):
    return "  вҖ”" if pct is None else f"{round(pct):>3d}%"

def _parse_iso(s):
    if not s:
        return None
    try:
        return datetime.fromisoformat(s)
    except ValueError:
        return None

def resets_at_str(iso):
    """Local clock time the window resets, e.g. '9:59pm' or 'Jun 25 3:29am'."""
    dt = _parse_iso(iso)
    if not dt:
        return ""
    if dt.tzinfo is None:
        dt = dt.replace(tzinfo=timezone.utc)
    local = dt.astimezone()
    now = datetime.now().astimezone()
    clock = f"{local.strftime('%-I:%M')}{local.strftime('%p').lower()}"
    if local.date() == now.date():
        return clock
    return f"{local.strftime('%b %-d')} {clock}"

# в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ messages в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

IND = "  "

def info(msg=""):
    print(msg)

def ok(msg):
    info(IND + green("вң“") + " " + msg)

def warn(msg):
    info(IND + yellow("!") + " " + msg)

def step(msg):
    info(IND + clay("вҖә") + " " + msg)

def hint(msg):
    info(IND + dim(msg))

def die(msg, code=1):
    print(IND + red("вң—") + " " + msg, file=sys.stderr)
    sys.exit(code)

# в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ banner / help в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

_WORDMARK = [
    " в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв•—      в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв•—   в–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—",
    "в–Ҳв–Ҳв•”в•җв•җв•җв•җв•қв–Ҳв–Ҳв•‘     в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•”в•җв•җв•җв•җв•қ",
    "в–Ҳв–Ҳв•‘     в–Ҳв–Ҳв•‘     в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—  ",
    "в–Ҳв–Ҳв•‘     в–Ҳв–Ҳв•‘     в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв•қ  ",
    "в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—",
    " в•ҡв•җв•җв•җв•җв•җв•қв•ҡв•җв•җв•җв•җв•җв•җв•қв•ҡв•җв•қ  в•ҡв•җв•қ в•ҡв•җв•җв•җв•җв•җв•қ в•ҡв•җв•җв•җв•җв•җв•қ в•ҡв•җв•җв•җв•җв•җв•җв•қ",
]

def render_banner():
    out = []
    if term_width() >= 54:
        width = max(len(l) for l in _WORDMARK)
        for line in _WORDMARK:
            out.append(IND + gradient(line.ljust(width), CLAY_LITE, CLAY_DARK))
        out.append(IND + bold(clay("auth")) +
                   dim("  В·  multi-account switcher for Claude Code"))
    else:
        out.append(IND + clay("в—Ҷ ") + bold(ink("claude-auth")))
        out.append(IND + dim("multi-account switcher for Claude Code"))
    return "\n".join(out)

def render_help():
    rows = [
        ("login",   "[name]",       "Sign in fresh, then save as a profile"),
        ("add",     "[name]",       "Save the currently logged-in account"),
        ("switch",  "[name]",       "Switch to a saved account"),
        ("usage",   "[name]",       "Show rate-limit usage across accounts"),
        ("list",    "",             "List saved accounts" + dim("  (alias: ls)")),
        ("current", "",             "Show the active account" + dim("  (alias: whoami)")),
        ("rename",  "<old> <new>",  "Rename a saved profile"),
        ("remove",  "<name>",       "Delete a saved profile" + dim("  (alias: rm)")),
    ]
    cw = max(len(c) for c, _, _ in rows)
    aw = max(len(a) for _, a, _ in rows)
    L = ["", render_banner(), ""]
    L.append(IND + bold(clay("USAGE")))
    L.append(IND * 2 + ink("claude-auth") + " " + dim("<command> [options]"))
    L.append("")
    L.append(IND + bold(clay("COMMANDS")))
    for c, a, d in rows:
        L.append(IND * 2 + bold(ink(vpad(c, cw))) + "  " +
                 dim(vpad(a, aw)) + "  " + d)
    L.append("")
    L.append(IND + bold(clay("EXAMPLES")))
    for ex in ("claude-auth login work", "claude-auth switch personal", "claude-auth list"):
        L.append(IND * 2 + dim("$ ") + clay(ex))
    L.append("")
    L.append(IND + dim("docs   ") + cyan(REPO) + dim(f"   В·   v{__version__}"))
    L.append("")
    return "\n".join(L)

# в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ keychain в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

def _kc_account_for_live():
    """The macOS account name the live credential item is stored under."""
    try:
        out = subprocess.run(
            ["security", "find-generic-password", "-s", LIVE_SERVICE],
            capture_output=True, text=True,
        ).stdout
        for line in out.splitlines():
            line = line.strip()
            if line.startswith('"acct"<blob>='):
                val = line.split("=", 1)[1].strip()
                if val.startswith('"') and val.endswith('"'):
                    return val[1:-1]
    except Exception:
        pass
    return getpass.getuser()

def kc_read(service, account):
    """Return the password string for a keychain item, or None if absent."""
    r = subprocess.run(
        ["security", "find-generic-password", "-s", service, "-a", account, "-w"],
        capture_output=True, text=True,
    )
    if r.returncode != 0:
        return None
    return r.stdout.rstrip("\n")

def kc_write(service, account, secret, label=None):
    """Create or update a keychain item in place (-U preserves ACL)."""
    cmd = ["security", "add-generic-password", "-U",
           "-s", service, "-a", account, "-w", secret]
    if label:
        cmd += ["-l", label]
    r = subprocess.run(cmd, capture_output=True, text=True)
    if r.returncode != 0:
        die(f"keychain write failed: {r.stderr.strip()}")

def kc_delete(service, account):
    subprocess.run(
        ["security", "delete-generic-password", "-s", service, "-a", account],
        capture_output=True, text=True,
    )

# в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ live credential + identity в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

def read_live_credential():
    acct = _kc_account_for_live()
    raw = kc_read(LIVE_SERVICE, acct)
    if raw is None:
        return None, acct
    try:
        return json.loads(raw), acct
    except json.JSONDecodeError:
        die("live Keychain credential is not valid JSON")

def write_live_credential(blob, acct):
    kc_write(LIVE_SERVICE, acct, json.dumps(blob), label=LIVE_SERVICE)

def read_claude_json():
    try:
        with open(CLAUDE_JSON) as f:
            return json.load(f)
    except FileNotFoundError:
        return {}
    except json.JSONDecodeError:
        die(f"{CLAUDE_JSON} is not valid JSON")

def write_claude_json(data):
    # atomic write to avoid corrupting the (large) config on crash
    tmp = CLAUDE_JSON + ".claude-auth.tmp"
    with open(tmp, "w") as f:
        json.dump(data, f, indent=2)
    os.replace(tmp, CLAUDE_JSON)

def current_identity():
    """(oauthAccount dict, userID) for the currently logged-in account."""
    cj = read_claude_json()
    return cj.get("oauthAccount") or {}, cj.get("userID")

# в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ index в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

def load_index():
    try:
        with open(INDEX_PATH) as f:
            return json.load(f)
    except FileNotFoundError:
        return {"accounts": {}}
    except json.JSONDecodeError:
        die(f"{INDEX_PATH} is corrupt")

def save_index(idx):
    os.makedirs(STORE_DIR, exist_ok=True)
    try:
        os.chmod(STORE_DIR, 0o700)
    except OSError:
        pass
    tmp = INDEX_PATH + ".tmp"
    with open(tmp, "w") as f:
        json.dump(idx, f, indent=2)
    os.replace(tmp, INDEX_PATH)
    try:
        os.chmod(INDEX_PATH, 0o600)
    except OSError:
        pass

def active_name(idx):
    """Name of the saved profile matching the live identity, or None."""
    oauth, _ = current_identity()
    uuid = oauth.get("accountUuid")
    if not uuid:
        return None
    for name, p in idx["accounts"].items():
        if p.get("accountUuid") == uuid:
            return name
    return None

# в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ snapshot / restore в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

def snapshot_into(name, idx, *, quiet=False):
    """Capture the live account into profile `name`."""
    blob, _ = read_live_credential()
    if blob is None:
        die("no live Claude Code credential found in Keychain вҖ” log in first")
    oauth, user_id = current_identity()

    kc_write(STORE_SERVICE, name, json.dumps(blob), label=f"claude-auth: {name}")
    cred = blob.get("claudeAiOauth", {})
    idx["accounts"][name] = {
        "email": oauth.get("emailAddress"),
        "organizationName": oauth.get("organizationName"),
        "accountUuid": oauth.get("accountUuid"),
        "userID": user_id,
        "subscriptionType": cred.get("subscriptionType"),
        "expiresAt": cred.get("expiresAt"),
        "oauthAccount": oauth,
        "addedAt": idx["accounts"].get(name, {}).get("addedAt", int(time.time())),
        "updatedAt": int(time.time()),
    }
    save_index(idx)
    if not quiet:
        email = oauth.get("emailAddress") or "?"
        ok(f"Saved {bold(clay(name))}  {dim('В· ' + email)}")

def restore(name, idx):
    """Make profile `name` the active account."""
    if name not in idx["accounts"]:
        die(f"no such account: {name}")
    raw = kc_read(STORE_SERVICE, name)
    if raw is None:
        die(f"stored credential for {name} is missing from Keychain (was it deleted?)")
    blob = json.loads(raw)

    _, acct = read_live_credential()
    write_live_credential(blob, acct)

    # restore identity into ~/.claude.json so the displayed account is correct
    prof = idx["accounts"][name]
    cj = read_claude_json()
    if prof.get("oauthAccount"):
        cj["oauthAccount"] = prof["oauthAccount"]
    if prof.get("userID") is not None:
        cj["userID"] = prof["userID"]
    write_claude_json(cj)

# в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ commands в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

def cmd_login(args):
    """Drive `claude auth login`, then save whatever account we land on."""
    idx = load_index()

    # don't lose the outgoing account вҖ” login overwrites the live credential
    active = active_name(idx)
    if active:
        snapshot_into(active, idx, quiet=True)
    prev_oauth, _ = current_identity()
    prev_uuid = prev_oauth.get("accountUuid")

    cmd = ["claude", "auth", "login"]
    if args.console:
        cmd.append("--console")
    if args.sso:
        cmd.append("--sso")
    if args.email:
        cmd += ["--email", args.email]

    info()
    step("Launching " + clay("claude auth login") + " вҖ” finish sign-in in your browserвҖҰ")
    info()
    try:
        r = subprocess.run(cmd)
    except FileNotFoundError:
        die("`claude` CLI not found on PATH")
    if r.returncode != 0:
        die("login was cancelled or failed; nothing saved")

    new_oauth, _ = current_identity()
    new_uuid = new_oauth.get("accountUuid")
    if not new_uuid:
        die("login finished but no account could be read вҖ” try `claude-auth add`")

    email = new_oauth.get("emailAddress") or ""
    name = args.name or (email.split("@")[0] if email else None)
    if not name:
        die("could not infer a name; pass one: claude-auth login <name>")

    for n, p in idx["accounts"].items():
        if p.get("accountUuid") == new_uuid and n != name:
            warn(f"this account is already saved as {bold(n)}")

    info()
    snapshot_into(name, idx)
    if prev_uuid and prev_uuid == new_uuid:
        hint("(same account as before вҖ” refreshed its stored tokens)")
    info()

def cmd_add(args):
    idx = load_index()
    oauth, _ = current_identity()
    email = oauth.get("emailAddress") or ""
    name = args.name or (email.split("@")[0] if email else None)
    if not name:
        die("could not infer a name; pass one: claude-auth add <name>")
    if name in idx["accounts"] and not args.force:
        die(f"'{name}' already exists вҖ” pass {bold('--force')} to overwrite")
    info()
    snapshot_into(name, idx)
    info()

def _cell(text, w, colorfn, align="left"):
    return " " + colorfn(vpad(text, w, align)) + " "

def cmd_list(args):
    idx = load_index()
    accts = idx["accounts"]
    info()
    if not accts:
        hint("No saved accounts yet.")
        info(IND + dim("Get started:  ") + clay("claude-auth login <name>") +
             dim("  or  ") + clay("claude-auth add"))
        info()
        return

    active = active_name(idx)
    rows = []
    for name, p in sorted(accts.items()):
        rows.append({
            "active": name == active,
            "name": name,
            "email": p.get("email") or "вҖ”",
            "org": p.get("organizationName") or "вҖ”",
            "plan": p.get("subscriptionType") or "вҖ”",
            "saved": rel_time(p.get("updatedAt")),
        })

    w_name = max(len("ACCOUNT"), max(len(r["name"]) for r in rows))
    w_mail = max(len("EMAIL"),   max(len(r["email"]) for r in rows))
    w_org  = max(len("ORG"),     max(len(r["org"]) for r in rows))
    w_plan = max(len("PLAN"),    max(len(r["plan"]) for r in rows))
    w_save = max(len("SAVED"),   max(len(r["saved"]) for r in rows))
    widths = [1, w_name, w_mail, w_org, w_plan, w_save]

    def border(l, m, rt):
        return dim(l + m.join("в”Җ" * (w + 2) for w in widths) + rt)

    def line(cells):
        return IND + dim("в”Ӯ") + dim("в”Ӯ").join(cells) + dim("в”Ӯ")

    H = lambda s: bold(dim(s))
    n = len(rows)
    info(IND + bold(clay("Accounts")) + dim(f"   В·   {n} saved"))
    info()
    info(IND + border("в”Ң", "в”¬", "в”җ"))
    info(line([_cell("", 1, dim),
               _cell("ACCOUNT", w_name, H), _cell("EMAIL", w_mail, H),
               _cell("ORG", w_org, H), _cell("PLAN", w_plan, H),
               _cell("SAVED", w_save, H)]))
    info(IND + border("в”ң", "в”ј", "в”Ө"))
    for r in rows:
        a = r["active"]
        dot = green("в—Ҹ") if a else dim("в—Ӣ")
        name_c = (lambda s: bold(clay(s))) if a else ink
        text_c = ink if a else dim
        plan_c = green if a else dim
        info(line([" " + dot + " ",
                   _cell(r["name"], w_name, name_c),
                   _cell(r["email"], w_mail, text_c),
                   _cell(r["org"], w_org, text_c),
                   _cell(r["plan"], w_plan, plan_c),
                   _cell(r["saved"], w_save, dim)]))
    info(IND + border("в””", "в”ҙ", "в”ҳ"))
    info()
    info(IND + green("в—Ҹ") + dim(" active") + "    " + dim("в—Ӣ saved"))
    if not active:
        info()
        warn("active account isn't saved yet вҖ” run " + clay("claude-auth add"))
    info()

def cmd_current(args):
    idx = load_index()
    active = active_name(idx)
    oauth, _ = current_identity()
    email = oauth.get("emailAddress")
    org = oauth.get("organizationName")
    info()
    if active:
        p = idx["accounts"].get(active, {})
        info(IND + green("в—Ҹ") + " " + bold(clay(active)))
        info(IND * 2 + ink(email or "?"))
        meta = "  В·  ".join(x for x in [org, p.get("subscriptionType")] if x)
        if meta:
            info(IND * 2 + dim(meta))
    elif email:
        info(IND + yellow("в—Ҹ") + " " + ink(email) + dim("   (not saved)"))
        info(IND * 2 + dim("run ") + clay("claude-auth add") + dim(" to save it"))
    else:
        hint("not logged in")
    info()

def _token_for(name, idx, active):
    """Access token for an account: live blob if active, else its backup."""
    if name == active:
        blob, _ = read_live_credential()
    else:
        raw = kc_read(STORE_SERVICE, name)
        blob = json.loads(raw) if raw else None
    if not blob:
        return None
    return blob.get("claudeAiOauth", {}).get("accessToken")

def _refresh_usage(name, idx, active):
    """Fetch live usage for one account, caching the result. Returns dict."""
    token = _token_for(name, idx, active)
    if not token:
        return {"name": name, "live": None, "error": "no token"}
    data, err = fetch_usage(token)
    if data is None:
        return {"name": name, "live": None, "error": err}
    norm = parse_usage(data)
    norm["fetchedAt"] = int(time.time())
    idx["accounts"][name]["usage"] = norm
    return {"name": name, "live": norm, "error": None}

def cmd_usage(args):
    idx = load_index()
    accts = idx["accounts"]
    if not accts:
        info()
        hint("No saved accounts yet вҖ” run " + clay("claude-auth login <name>"))
        info()
        return
    active = active_name(idx)
    names = [args.name] if args.name else sorted(accts)
    if args.name and args.name not in accts:
        die(f"no such account: {bold(args.name)}")

    if _TTY:
        sys.stdout.write(IND + clay("вҖә") + " Fetching usageвҖҰ")
        sys.stdout.flush()
    with concurrent.futures.ThreadPoolExecutor(max_workers=8) as ex:
        results = {r["name"]: r for r in ex.map(
            lambda n: _refresh_usage(n, idx, active), names)}
    save_index(idx)
    if _TTY:
        sys.stdout.write("\r\033[2K")  # return to start, clear the "Fetching" line
        sys.stdout.flush()

    if args.name:
        _usage_detail(args.name, idx, results[args.name], active)
    else:
        _usage_table(names, idx, results, active)

def _usage_source(name, idx, res):
    """Return (usage_dict, freshness_label) using live result or cache."""
    if res["live"]:
        return res["live"], "live"
    cached = idx["accounts"][name].get("usage")
    if cached:
        return cached, rel_time(cached.get("fetchedAt"))
    return None, res["error"] or "unavailable"

def _win_cell(win, barw=10):
    """Bar + percent + reset-time for one usage window."""
    if not win:
        return bar(None, barw) + "   вҖ”"
    pct = win["pct"]
    cell = bar(pct, barw) + " " + sev_color(pct)(pct_str(pct))
    rt = resets_at_str(win.get("resets_at"))
    if rt:
        cell += dim("  " + rt)
    return cell

def _usage_table(names, idx, results, active):
    BARW = 10
    rows = []
    for name in names:
        u, fresh = _usage_source(name, idx, results[name])
        rows.append({
            "name": name, "active": name == active, "fresh": fresh,
            "has": bool(u),
            "sess": _win_cell(u.get("session") if u else None, BARW),
            "week": _win_cell(u.get("week") if u else None, BARW),
        })
    w_name = max(len("ACCOUNT"), max(len(r["name"]) for r in rows))
    w_sess = max(len("SESSION"), max(vlen(r["sess"]) for r in rows))
    w_week = max(len("WEEK"),    max(vlen(r["week"]) for r in rows))
    w_fresh = max(len("UPDATED"), max(len(r["fresh"]) for r in rows))
    widths = [1, w_name, w_sess, w_week, w_fresh]

    def border(l, m, rt):
        return dim(l + m.join("в”Җ" * (w + 2) for w in widths) + rt)

    def line(cells):
        return IND + dim("в”Ӯ") + dim("в”Ӯ").join(cells) + dim("в”Ӯ")

    H = lambda s: bold(dim(s))
    info()
    info(IND + bold(clay("Usage")) + dim("   В·   weekly limit is the one that bites"))
    info()
    info(IND + border("в”Ң", "в”¬", "в”җ"))
    info(line([_cell("", 1, dim),
               _cell("ACCOUNT", w_name, H),
               _cell("SESSION", w_sess, H),
               _cell("WEEK", w_week, H),
               _cell("UPDATED", w_fresh, H)]))
    info(IND + border("в”ң", "в”ј", "в”Ө"))
    for r in rows:
        a = r["active"]
        dot = green("в—Ҹ") if a else dim("в—Ӣ")
        name_c = (lambda s: bold(clay(s))) if a else ink
        fresh_c = green if r["fresh"] == "live" else (dim if r["has"] else yellow)
        info(line([" " + dot + " ",
                   _cell(r["name"], w_name, name_c),
                   " " + vpad(r["sess"], w_sess) + " ",
                   " " + vpad(r["week"], w_week) + " ",
                   _cell(r["fresh"], w_fresh, fresh_c)]))
    info(IND + border("в””", "в”ҙ", "в”ҳ"))
    info()
    info(IND + sev_color(10)("в–Ҳ") + dim(" <50%   ") + sev_color(60)("в–Ҳ") +
         dim(" <80%   ") + sev_color(90)("в–Ҳ") + dim(" вүҘ80%"))
    info()

def _usage_detail(name, idx, res, active):
    u, fresh = _usage_source(name, idx, res)
    p = idx["accounts"][name]
    dot = green("в—Ҹ") if name == active else dim("в—Ӣ")
    info()
    info(IND + dot + " " + bold(clay(name)) + dim("  В· " + (p.get("email") or "")))
    info()
    if not u:
        warn(f"usage unavailable ({res['error']})")
        if name != active:
            hint("the stored token may be expired вҖ” " + clay(f"claude-auth switch {name}") +
                 dim(" refreshes it"))
        info()
        return
    label_w = 17
    BARW = 20
    def row(label, win):
        if not win:
            info(IND + dim(vpad(label, label_w)) + " " + dim("в–‘" * BARW) + "   вҖ”")
            return
        pct = win["pct"]
        info(IND + ink(vpad(label, label_w)) + " " + bar(pct, BARW) + " " +
             sev_color(pct)(pct_str(pct)) +
             dim(f"   resets {resets_at_str(win['resets_at'])}"))
    row("Session (5h)", u.get("session"))
    row("Week (all models)", u.get("week"))
    row("Week (Sonnet)", u.get("week_sonnet"))
    if u.get("week_opus"):
        row("Week (Opus)", u.get("week_opus"))
    info()
    info(IND + dim("updated " + fresh))
    info()

def cmd_switch(args):
    idx = load_index()
    accts = idx["accounts"]
    if not accts:
        die("no saved accounts yet вҖ” run " + clay("claude-auth login <name>"))

    name = args.name
    if not name:
        name = _interactive_pick(idx)
        if not name:
            return

    if name not in accts:
        die(f"no such account: {bold(name)}")

    active = active_name(idx)
    if active == name and not args.force:
        info()
        step(f"Already on {bold(clay(name))}")
        info()
        return

    # keep the outgoing account's stored copy fresh (tokens rotate, MCP auth, etc.)
    if active and not args.no_save:
        snapshot_into(active, idx, quiet=True)

    restore(name, idx)
    p = accts[name]
    info()
    ok(f"Switched to {bold(clay(name))}  {dim('В· ' + (p.get('email') or ''))}")
    hint("вҶ» restart Claude Code (and running sessions) to use this account")
    info()

def _interactive_pick(idx):
    accts = sorted(idx["accounts"].items())
    active = active_name(idx)
    w = max(len(n) for n, _ in accts)
    info()
    info(IND + bold(clay("Select an account")))
    info()
    for i, (name, p) in enumerate(accts, 1):
        dot = green("в—Ҹ") if name == active else dim("в—Ӣ")
        info(IND * 2 + cyan(f"{i}") + "  " + dot + " " +
             bold(ink(vpad(name, w))) + "   " + dim(p.get("email") or ""))
    info()
    try:
        choice = input(IND + clay("вҖә") + " ").strip()
    except (EOFError, KeyboardInterrupt):
        info()
        return None
    if not choice:
        return None
    if choice.isdigit() and 1 <= int(choice) <= len(accts):
        return accts[int(choice) - 1][0]
    if choice in idx["accounts"]:
        return choice
    die(f"invalid selection: {choice}")

def cmd_rename(args):
    idx = load_index()
    if args.old not in idx["accounts"]:
        die(f"no such account: {bold(args.old)}")
    if args.new in idx["accounts"]:
        die(f"'{args.new}' already exists")
    raw = kc_read(STORE_SERVICE, args.old)
    if raw is not None:
        kc_write(STORE_SERVICE, args.new, raw, label=f"claude-auth: {args.new}")
        kc_delete(STORE_SERVICE, args.old)
    idx["accounts"][args.new] = idx["accounts"].pop(args.old)
    save_index(idx)
    info()
    ok(f"Renamed {bold(args.old)} {dim('вҶ’')} {bold(clay(args.new))}")
    info()

def cmd_remove(args):
    idx = load_index()
    if args.name not in idx["accounts"]:
        die(f"no such account: {bold(args.name)}")
    if active_name(idx) == args.name and not args.force:
        die(f"'{args.name}' is the active account вҖ” pass {bold('--force')} to remove it")
    kc_delete(STORE_SERVICE, args.name)
    del idx["accounts"][args.name]
    save_index(idx)
    info()
    ok(f"Removed {bold(args.name)}")
    info()

# в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ arg parsing в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

class BrandParser(argparse.ArgumentParser):
    def format_help(self):
        return render_help() + "\n"
    def error(self, message):
        die(message + dim("   В·   see ") + clay("claude-auth --help"), code=2)

def build_parser():
    p = BrandParser(prog="claude-auth", add_help=True,
                    description="Switch between multiple Claude Code accounts (macOS).")
    p.add_argument("-V", "--version", action="version",
                   version=f"claude-auth {__version__}")
    sub = p.add_subparsers(dest="cmd")

    lg = sub.add_parser("login", help="sign in fresh and save the result as a profile")
    lg.add_argument("name", nargs="?", help="profile name (default: email prefix)")
    lg.add_argument("--email", help="pre-populate the email on the login page")
    lg.add_argument("--console", action="store_true",
                    help="use Anthropic Console (API billing) instead of subscription")
    lg.add_argument("--sso", action="store_true", help="force the SSO login flow")
    lg.set_defaults(func=cmd_login)

    a = sub.add_parser("add", help="save the current account as a named profile")
    a.add_argument("name", nargs="?", help="profile name (default: email prefix)")
    a.add_argument("-f", "--force", action="store_true", help="overwrite if exists")
    a.set_defaults(func=cmd_add)

    for alias in ("list", "ls"):
        l = sub.add_parser(alias, help="list saved accounts")
        l.set_defaults(func=cmd_list)

    s = sub.add_parser("switch", help="switch to a saved account")
    s.add_argument("name", nargs="?", help="account to switch to (interactive if omitted)")
    s.add_argument("-f", "--force", action="store_true", help="switch even if already active")
    s.add_argument("--no-save", action="store_true",
                   help="don't refresh the outgoing account's stored copy")
    s.set_defaults(func=cmd_switch)

    for alias in ("current", "whoami"):
        c = sub.add_parser(alias, help="show the active account")
        c.set_defaults(func=cmd_current)

    u = sub.add_parser("usage", help="show rate-limit usage for your accounts")
    u.add_argument("name", nargs="?", help="account to detail (default: all)")
    u.set_defaults(func=cmd_usage)

    rn = sub.add_parser("rename", help="rename a saved account")
    rn.add_argument("old")
    rn.add_argument("new")
    rn.set_defaults(func=cmd_rename)

    for alias in ("remove", "rm"):
        rm = sub.add_parser(alias, help="delete a saved account")
        rm.add_argument("name")
        rm.add_argument("-f", "--force", action="store_true",
                        help="remove even if it's the active account")
        rm.set_defaults(func=cmd_remove)

    return p

def main():
    if sys.platform != "darwin":
        die("claude-auth currently supports macOS only (uses the login Keychain).")
    parser = build_parser()
    args = parser.parse_args()
    if not getattr(args, "func", None):
        print(render_help())
        sys.exit(0)
    args.func(args)

if __name__ == "__main__":
    main()
